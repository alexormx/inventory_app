<% # Collapsible Section Card
   # Locals: id (string), title (string), icon (string), collapsed (boolean), &block
   collapsed ||= false
   icon ||= 'fa-chart-bar'
%>
<div class="card mb-4">
  <div class="card-header d-flex justify-content-between align-items-center dashboard-collapsible-toggle"
       data-bs-toggle="collapse"
       data-bs-target="#collapse-<%= id %>"
       aria-expanded="<%= !collapsed %>"
       aria-controls="collapse-<%= id %>">
    <span><i class="fa-solid <%= icon %> me-2"></i><%= title %></span>
    <i class="fa-solid fa-chevron-down collapse-indicator"></i>
  </div>
  <div class="collapse <%= 'show' unless collapsed %>" id="collapse-<%= id %>">
    <div class="card-body">
      <%= yield %>
    </div>
  </div>
</div>
