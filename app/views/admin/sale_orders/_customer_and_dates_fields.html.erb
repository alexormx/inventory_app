<%# Parcial: Campos de cliente, fecha, estado y notas %>
<% sale_status_labels = {
  "Pending" => "Pendiente",
  "Confirmed" => "Confirmada",
  "Preparing" => "Preparando",
  "In Transit" => "En tránsito",
  "Delivered" => "Entregada",
  "Canceled" => "Cancelada",
  "Returned" => "Devuelta"
} %>

<div class="col-12">
  <div class="admin-order-section-intro">
    <div>
      <p class="admin-order-section-eyebrow mb-1">Cliente y seguimiento</p>
      <h6 class="admin-order-section-title mb-1">Cliente, estado y contexto comercial</h6>
      <p class="admin-order-section-copy mb-0">Consolida aquí la relación con el cliente, la fecha operativa y cualquier nota útil para la entrega o cobranza.</p>
    </div>
  </div>
</div>

<div class="col-md-6">
  <%= f.label :user_id, "Cliente", class: "form-label" %>
  <div data-controller="user-suggest" data-user-suggest-role-value="customer" class="position-relative">
    <div class="input-group">
      <span class="input-group-text"><i class="fa-solid fa-user"></i></span>
      <input type="text" class="form-control" data-user-suggest-target="input" placeholder="Buscar cliente..." value="<%= f.object.user&.name %>" data-action="input->user-suggest#input keydown->user-suggest#keydown">
    </div>
    <%= f.hidden_field :user_id, data: { 'user-suggest-target': 'hidden' } %>
    <div class="form-text admin-order-field-note" data-user-suggest-target="hint">
      <i class="fa-solid fa-circle-info"></i> Escribe el nombre o email del cliente
    </div>
    <div data-user-suggest-target="results" class="admin-user-suggest-results"></div>
  </div>
</div>

<div class="col-md-3">
  <%= f.label :order_date, "Fecha de Orden", class: "form-label" %>
  <div class="input-group">
    <span class="input-group-text"><i class="fa-solid fa-calendar"></i></span>
    <%= f.date_field :order_date, class: "form-control" %>
  </div>
</div>

<div class="col-md-3">
  <%= f.label :status, "Estado", class: "form-label" %>
  <div class="input-group">
    <span class="input-group-text"><i class="fa-solid fa-flag"></i></span>
    <%= f.select :status,
        SaleOrder::STATUSES.map { |status| [sale_status_labels.fetch(status, status), status] },
        {},
        class: "form-select" %>
  </div>
  <div class="form-text admin-order-field-note">
    <i class="fa-solid fa-circle-info"></i> El estado refleja el avance comercial y logístico de la orden.
  </div>
</div>

<div class="col-12">
  <%= f.label :notes, "Notas", class: "form-label" %>
  <div class="input-group">
    <span class="input-group-text"><i class="fa-solid fa-note-sticky"></i></span>
    <%= f.text_area :notes, class: "form-control admin-order-textarea", rows: 3, placeholder: "Notas adicionales sobre esta orden de venta..." %>
  </div>
  <div class="form-text admin-order-field-note">
    <i class="fa-solid fa-circle-info"></i> Información adicional sobre el cliente o pedido
  </div>
</div>
