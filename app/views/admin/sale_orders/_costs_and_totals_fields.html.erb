<%# Parcial: Campos de impuestos, descuentos y totales %>
<div class="col-12">
  <div class="admin-order-section-intro admin-order-section-intro--soft">
    <div>
      <p class="admin-order-section-eyebrow mb-1">Cobro</p>
      <h6 class="admin-order-section-title mb-1"><i class="fa-solid fa-calculator me-2"></i>Cálculos financieros</h6>
      <p class="admin-order-section-copy mb-0">Ajusta impuestos y descuentos para revisar el importe final que se cobrará al cliente.</p>
    </div>
  </div>
</div>

<div class="col-md-4">
  <%= f.label :tax_rate, "Tasa de Impuesto (%)", class: "form-label" %>
  <div class="input-group input-group-sm">
    <span class="input-group-text"><i class="fa-solid fa-percent"></i></span>
    <%= f.number_field :tax_rate, step: 0.01, class: "form-control" %>
  </div>
  <div class="form-text admin-order-field-note">
    <i class="fa-solid fa-circle-info"></i> Porcentaje de impuesto (IVA)
  </div>
</div>

<div class="col-md-4">
  <%= f.label :discount, "Descuento", class: "form-label" %>
  <div class="input-group input-group-sm">
    <span class="input-group-text"><i class="fa-solid fa-tags"></i></span>
    <%= f.number_field :discount, step: 0.01, class: "form-control" %>
  </div>
</div>

<div class="col-md-4">
  <div class="admin-order-field-note pt-md-4 mt-md-2">
    <i class="fa-solid fa-circle-info"></i> El descuento se descuenta después del subtotal y antes del total final.
  </div>
</div>

<div class="col-12 mt-4">
  <div class="row g-3">
    <div class="col-md-3">
      <div class="admin-order-metric admin-order-metric--highlight">
        <div class="admin-order-metric-label">Subtotal de productos</div>
        <div class="admin-order-metric-value" id="display-subtotal">
          <%= number_to_currency(sale_order.subtotal, precision: 2) %>
        </div>
        <div class="admin-order-metric-note">Base de productos</div>
      </div>
    </div>

    <div class="col-md-2">
      <div class="admin-order-metric admin-order-metric--muted">
        <div class="admin-order-metric-label">Impuesto total</div>
        <div class="admin-order-metric-value admin-order-metric-value--compact" id="display-total-tax">
          <%= number_to_currency(sale_order.total_tax, precision: 2) %>
        </div>
        <div class="admin-order-metric-note">IVA</div>
      </div>
    </div>

    <div class="col-md-2">
      <div class="admin-order-metric admin-order-metric--muted">
        <div class="admin-order-metric-label">Descuento</div>
        <div class="admin-order-metric-value admin-order-metric-value--compact" id="display-discount">
          <%= number_to_currency(sale_order.discount, precision: 2) %>
        </div>
        <div class="admin-order-metric-note">Rebaja</div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="admin-order-metric admin-order-metric--success">
        <div class="admin-order-metric-label">Total de la orden</div>
        <div class="admin-order-metric-value admin-order-metric-value--strong" id="display-total">
          <%= number_to_currency(sale_order.total_order_value, precision: 2) %>
        </div>
        <div class="admin-order-metric-note">Total a cobrar</div>
      </div>
    </div>
  </div>
</div>

<%# Hidden fields para que Rails reciba los valores %>
<%= f.hidden_field :subtotal, id: "sale_order_subtotal" %>
<%= f.hidden_field :total_tax %>
<%= f.hidden_field :total_order_value %>
