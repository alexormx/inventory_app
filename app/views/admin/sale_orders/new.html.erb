<div class="admin-page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <p class="admin-page-eyebrow mb-1">Comercial</p>
    <h1 class="h4 mb-0"><i class="fa-solid fa-circle-plus"></i> Nueva orden de venta</h1>
  </div>
  <span class="badge admin-page-badge">Cliente, productos y total en una sola vista</span>
</div>

<% if @sale_order.errors.any? %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <h5 class="alert-heading">
      <i class="fa-solid fa-triangle-exclamation"></i> Errores al guardar
    </h5>
    <ul class="mb-0">
      <% @sale_order.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>

<div class="order-context" data-context="sale-order">
  <%= form_with model: [:admin, @sale_order], local: true, class: "row g-3" do |f| %>
    <div class="col-lg-9">
      <!-- Sección 1: Información Básica -->
      <div class="card admin-order-card mb-3">
        <div class="card-header admin-order-card-header">
          <h5 class="mb-0">
            <i class="fa-solid fa-circle-info"></i> Información Básica
          </h5>
        </div>
        <div class="card-body row g-3">
          <%= render "customer_and_dates_fields", f: f %>
        </div>
      </div>

      <!-- Sección 2: Productos -->
      <div class="card admin-order-card mb-3">
        <div class="card-header admin-order-card-header">
          <h5 class="mb-0">
            <i class="fa-solid fa-boxes-stacked"></i> Productos de la Orden
          </h5>
        </div>
        <div class="card-body">
          <%= render "admin/shared/item_search_and_table", f: f, context: "sale" %>
        </div>
      </div>

      <!-- Sección 3: Cálculos y Totales -->
      <div class="card admin-order-card mb-3">
        <div class="card-header admin-order-card-header">
          <h5 class="mb-0">
            <i class="fa-solid fa-dollar-sign"></i> Impuestos, Descuentos y Totales
          </h5>
        </div>
        <div class="card-body row g-3">
          <%= render "costs_and_totals_fields", f: f, sale_order: @sale_order %>
        </div>
      </div>
    </div>

    <!-- Panel lateral: Resumen -->
    <div class="col-lg-3">
      <%= render "summary_sidebar", f: f, sale_order: @sale_order %>
    </div>
  <% end %>
</div>
