<h2 class="mb-3 d-flex align-items-center gap-2">
  <i class="fa-solid fa-comment-dots text-primary"></i> Comentarios del Blog
</h2>

<%# Filter tabs %>
<ul class="nav nav-tabs mb-3">
  <% %w[pending approved rejected all].each do |status| %>
    <li class="nav-item">
      <%= link_to admin_comments_path(status: status),
                  class: "nav-link #{'active' if @status_filter == status}" do %>
        <%= status.capitalize %>
        <span class="badge bg-secondary ms-1"><%= @counts[status.to_sym] %></span>
      <% end %>
    </li>
  <% end %>
</ul>

<% if @comments.any? %>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-3">Publicación</th>
              <th>Usuario</th>
              <th>Comentario</th>
              <th>Estado</th>
              <th class="text-end pe-3">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% @comments.each do |comment| %>
              <tr>
                <td class="ps-3" style="max-width: 220px;">
                  <%= link_to comment.post.title, post_path(comment.post),
                              target: '_blank', class: 'text-decoration-none small fw-semibold text-truncate d-inline-block', style: 'max-width: 220px;' %>
                </td>
                <td style="max-width: 150px;">
                  <small class="d-block fw-semibold text-truncate"><%= comment.user.name.presence || comment.user.email %></small>
                  <small class="text-muted"><%= l comment.created_at.to_date, format: :long %></small>
                </td>
                <td style="max-width: 360px;">
                  <small style="white-space: pre-line;"><%= comment.body %></small>
                </td>
                <td>
                  <% case comment.status %>
                  <% when 'pending' %>
                    <span class="badge bg-warning text-dark">Pendiente</span>
                  <% when 'approved' %>
                    <span class="badge bg-success">Aprobado</span>
                  <% when 'rejected' %>
                    <span class="badge bg-secondary">Rechazado</span>
                  <% end %>
                </td>
                <td class="text-end pe-3">
                  <% unless comment.approved? %>
                    <%= button_to approve_admin_comment_path(comment), method: :patch,
                                  class: 'btn btn-sm btn-success me-1', form: { style: 'display:inline-block' } do %>
                      <i class="fas fa-check"></i>
                    <% end %>
                  <% end %>
                  <% unless comment.rejected? %>
                    <%= button_to reject_admin_comment_path(comment), method: :patch,
                                  class: 'btn btn-sm btn-warning me-1', form: { style: 'display:inline-block' } do %>
                      <i class="fas fa-ban"></i>
                    <% end %>
                  <% end %>
                  <%= button_to admin_comment_path(comment), method: :delete,
                                class: 'btn btn-sm btn-outline-danger',
                                data: { turbo_confirm: '¿Eliminar definitivamente este comentario?' },
                                form: { style: 'display:inline-block' } do %>
                    <i class="fas fa-trash"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="p-3 border-top">
      <%= paginate @comments %>
    </div>
  </div>
<% else %>
  <div class="alert alert-light border text-center py-5">
    <i class="fas fa-inbox fa-2x text-muted mb-2"></i>
    <p class="text-muted mb-0">No hay comentarios <%= @status_filter == 'all' ? 'aún' : "con estado «#{@status_filter}»" %>.</p>
  </div>
<% end %>
