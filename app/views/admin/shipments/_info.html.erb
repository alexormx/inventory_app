<!-- admin/shipments/_info.html.erb -->
<% if sale_order.shipment.present? %>
  <% is_personal = sale_order.shipment.respond_to?(:delivery_personal?) && sale_order.shipment.delivery_personal? %>
  <div class="card mb-3">
    <div class="card-body">
      <h5 class="card-title">
        <% if is_personal %>
          🤝 Entrega Personal
          <span class="badge bg-success ms-1">En mano</span>
        <% else %>
          🚚 Shipment Info
        <% end %>
      </h5>
      <div class="row">
        <div class="col-md-4"><strong>Carrier:</strong> <%= sale_order.shipment.carrier %></div>
        <% unless is_personal %>
          <div class="col-md-4"><strong>Tracking #:</strong> <%= sale_order.shipment.tracking_number.presence || "—" %></div>
        <% end %>
        <div class="col-md-4"><strong>Status:</strong> <%= sale_order.shipment.status&.humanize || "—" %></div>
        <div class="col-md-4"><strong>Estimated Delivery:</strong> <%= sale_order.shipment.estimated_delivery %></div>
        <div class="col-md-4"><strong>Actual Delivery:</strong> <%= sale_order.shipment.actual_delivery || "—" %></div>
        <% unless is_personal %>
          <div class="col-md-4"><strong>Shipping Cost:</strong> <%= number_to_currency(sale_order.shipment.shipping_cost || 0, unit: 'MXN ') %></div>
        <% end %>
      </div>
    </div>
  </div>
<% else %>
  <div class="card mb-3">
    <div class="card-body">
      <p class="text-muted">No shipment assigned.</p>
    </div>
  </div>
<% end %>