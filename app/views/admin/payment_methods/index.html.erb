<h2 class="mb-3 d-flex align-items-center gap-2">
  <i class="fa-solid fa-credit-card"></i> Métodos de Pago
</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
  <p class="text-muted mb-0">Configura los métodos de pago disponibles para los clientes.</p>
  <%= link_to new_admin_payment_method_path, class: "btn btn-primary" do %>
    <i class="fa-solid fa-plus me-1"></i> Nuevo Método
  <% end %>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th style="width: 60px;">Orden</th>
            <th>Nombre</th>
            <th>Código</th>
            <th>Cuenta / CLABE</th>
            <th class="text-center">Estado</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if @payment_methods.any? %>
            <% @payment_methods.each do |method| %>
              <tr class="<%= 'table-secondary' unless method.active? %>">
                <td class="text-center"><%= method.position %></td>
                <td>
                  <strong><%= method.name %></strong>
                  <% if method.description.present? %>
                    <br><small class="text-muted"><%= truncate(method.description, length: 40) %></small>
                  <% end %>
                </td>
                <td><code><%= method.code %></code></td>
                <td>
                  <% if method.account_number.present? %>
                    <code class="small"><%= method.account_number %></code>
                    <% if method.bank_name.present? %>
                      <br><small class="text-muted"><%= method.bank_name %></small>
                    <% end %>
                  <% else %>
                    <span class="text-muted">-</span>
                  <% end %>
                </td>
                <td class="text-center">
                  <% if method.active? %>
                    <span class="badge bg-success">Activo</span>
                  <% else %>
                    <span class="badge bg-secondary">Inactivo</span>
                  <% end %>
                </td>
                <td class="text-end">
                  <div class="btn-group btn-group-sm">
                    <%= link_to edit_admin_payment_method_path(method), class: "btn btn-outline-primary", title: "Editar" do %>
                      <i class="fa-solid fa-pen-to-square"></i>
                    <% end %>
                    <%= button_to toggle_active_admin_payment_method_path(method), method: :patch, class: "btn btn-outline-#{method.active? ? 'warning' : 'success'}", title: method.active? ? 'Desactivar' : 'Activar', form: { data: { turbo_confirm: "El método de pago '#{method.name}' se #{method.active? ? 'desactivará' : 'activará'} para nuevas operaciones. ¿Deseas continuar?", confirm_title: "#{method.active? ? 'Desactivar' : 'Activar'} método de pago", confirm_confirm_label: method.active? ? 'Desactivar' : 'Activar' } } do %>
                      <i class="fa-solid fa-<%= method.active? ? 'toggle-off' : 'toggle-on' %>"></i>
                    <% end %>
                    <%= button_to admin_payment_method_path(method), method: :delete, class: "btn btn-outline-danger", title: "Eliminar", form: { data: { turbo_confirm: "Se eliminará el método de pago '#{method.name}'. Esta acción no se puede deshacer. ¿Deseas continuar?", confirm_title: 'Eliminar método de pago', confirm_confirm_label: 'Eliminar' } } do %>
                      <i class="fa-solid fa-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="text-center text-muted py-4">
                <i class="fa-solid fa-inbox fa-2x mb-2 d-block"></i>
                No hay métodos de pago configurados.
                <%= link_to "Crear el primero", new_admin_payment_method_path, class: "d-block mt-2" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <% if @payment_methods.respond_to?(:current_page) && @payment_methods.total_pages > 1 %>
    <div class="card-footer py-2">
      <%= paginate @payment_methods %>
    </div>
  <% end %>
</div>

<div class="mt-3">
  <%= link_to admin_settings_path, class: "btn btn-outline-secondary" do %>
    <i class="fa-solid fa-arrow-left me-1"></i> Volver a Settings
  <% end %>
</div>
