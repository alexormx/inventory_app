<% content_for :title, "Coleccionables" %>

<div class="admin-page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <p class="admin-page-eyebrow mb-1">Catálogo</p>
    <h2 class="mb-0 d-flex align-items-center gap-2">
      <i class="fa-solid fa-gem text-warning"></i> Coleccionables
    </h2>
    <small class="text-muted">Una pieza por fila — cada coleccionable es único.</small>
  </div>
  <%= link_to admin_collectibles_quick_add_path, class: 'btn btn-primary' do %>
    <i class="fa-solid fa-plus me-1"></i> Agregar coleccionable
  <% end %>
</div>

<%# Filtros %>
<div class="card mb-3">
  <div class="card-body py-2">
    <%= form_with url: admin_collectibles_path, method: :get, local: true, class: 'row g-2 align-items-center' do %>
      <div class="col-12 col-md-4">
        <div class="input-group input-group-sm">
          <%= text_field_tag :q, @q, class: 'form-control', placeholder: 'Buscar por nombre o SKU…' %>
          <button class="btn btn-primary" type="submit">Buscar</button>
        </div>
      </div>
      <div class="col-12 col-md-3">
        <%= select_tag :condition,
            options_for_select(
              [['Todas las condiciones', 'all']] +
              Admin::CollectiblesController::COLLECTIBLE_CONDITIONS.map { |c| [Inventory::CONDITION_LABELS[c] || c.titleize, c] },
              @condition_filter.presence || 'all'
            ),
            class: 'form-select form-select-sm', onchange: 'this.form.submit()' %>
      </div>
      <div class="col-12 col-md-3">
        <%= select_tag :status,
            options_for_select(
              [['Todos los estatus', 'all']] +
              Inventory.statuses.keys.map { |s| [inventory_status_label(s), s] },
              @status_filter.presence || 'all'
            ),
            class: 'form-select form-select-sm', onchange: 'this.form.submit()' %>
      </div>
      <div class="col-12 col-md-2 text-md-end">
        <%= link_to 'Limpiar', admin_collectibles_path, class: 'btn btn-sm btn-outline-secondary' %>
      </div>
    <% end %>
  </div>
</div>

<%# Resumen por condición %>
<div class="d-flex flex-wrap gap-2 mb-3">
  <% Admin::CollectiblesController::COLLECTIBLE_CONDITIONS.each do |c| %>
    <% count = @counts_by_condition[c].to_i %>
    <% next if count.zero? %>
    <span class="badge bg-light text-dark border">
      <%= Inventory::CONDITION_LABELS[c] || c.titleize %>: <strong><%= count %></strong>
    </span>
  <% end %>
</div>

<% if @collectibles.any? %>
  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th style="width:60px;">Foto</th>
            <th>Producto</th>
            <th>Condición</th>
            <th>Fecha compra</th>
            <th class="text-end">Costo</th>
            <th class="text-end">Precio venta</th>
            <th>Estatus</th>
            <th>Ubicación</th>
            <th>Notas</th>
            <th class="text-end" style="width:130px;">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @collectibles.each do |inv| %>
            <% prod = inv.product %>
            <tr>
              <td>
                <% img = inv.piece_images.attached? ? inv.piece_images.first : prod&.primary_product_image %>
                <% if img&.attached? || img.is_a?(ActiveStorage::Attachment) %>
                  <%= image_tag img, class: 'rounded border', style: 'width:48px;height:48px;object-fit:cover;' %>
                <% else %>
                  <div class="rounded border bg-light d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="fa-regular fa-image text-muted"></i>
                  </div>
                <% end %>
              </td>
              <td>
                <%= link_to prod&.product_name, admin_product_path(prod), class: 'fw-semibold text-decoration-none' if prod %>
                <% if prod %>
                  <div class="small text-muted"><%= prod.product_sku %></div>
                <% end %>
              </td>
              <td>
                <span class="badge bg-warning-subtle text-dark border">
                  <%= inv.condition_label %>
                </span>
              </td>
              <td>
                <%= (inv.purchase_date || inv.created_at.to_date).strftime('%Y-%m-%d') %>
              </td>
              <td class="text-end">
                <%= number_to_currency(inv.purchase_cost) %>
              </td>
              <td class="text-end">
                <% if inv.selling_price.present? %>
                  <%= number_to_currency(inv.selling_price) %>
                <% else %>
                  <span class="text-muted small">— (usa producto)</span>
                <% end %>
              </td>
              <td>
                <span class="badge bg-<%= inventory_status_color(inv.status) %>">
                  <%= inventory_status_label(inv.status) %>
                </span>
              </td>
              <td class="small">
                <% if inv.inventory_location %>
                  <%= inv.inventory_location.full_path %>
                <% else %>
                  <span class="text-muted">Sin ubicación</span>
                <% end %>
              </td>
              <td class="small text-muted">
                <%= truncate(inv.notes.to_s, length: 60) %>
              </td>
              <td class="text-end">
                <%= link_to edit_admin_collectible_path(inv), class: 'btn btn-sm btn-outline-primary', title: 'Editar' do %>
                  <i class="fa-solid fa-pen"></i>
                <% end %>
                <% if prod %>
                  <%= link_to admin_product_path(prod), class: 'btn btn-sm btn-outline-secondary', title: 'Ver producto' do %>
                    <i class="fa-solid fa-arrow-up-right-from-square"></i>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-3">
    <%= paginate @collectibles if respond_to?(:paginate) %>
  </div>
<% else %>
  <div class="alert alert-info">
    No hay coleccionables que coincidan con los filtros.
    <%= link_to 'Agregar el primero', admin_collectibles_quick_add_path, class: 'alert-link' %>.
  </div>
<% end %>
