<div class="d-flex flex-wrap align-items-center justify-content-between mb-3 gap-2">
  <h2 class="mb-0"><i class="fas fa-newspaper text-primary me-2"></i>Blog</h2>
  <%= link_to new_admin_post_path, class: 'btn btn-danger' do %>
    <i class="fas fa-plus me-1"></i>Nueva publicación
  <% end %>
</div>

<ul class="nav nav-tabs mb-3">
  <% %w[all draft published archived].each do |status| %>
    <li class="nav-item">
      <%= link_to admin_posts_path(status: status), class: "nav-link #{'active' if @status_filter == status}" do %>
        <%= status == 'all' ? 'Todos' : status.capitalize %>
        <span class="badge bg-secondary ms-1"><%= @counts[status.to_sym] %></span>
      <% end %>
    </li>
  <% end %>
</ul>

<% if @posts.any? %>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-3">Título</th>
              <th>Estado</th>
              <th>Autor</th>
              <th>Publicado</th>
              <th>Actualizado</th>
              <th class="text-center">Visitas</th>
              <th class="text-end pe-3"></th>
            </tr>
          </thead>
          <tbody>
            <% @posts.each do |post| %>
              <tr>
                <td class="ps-3">
                  <%= link_to post.title, edit_admin_post_path(post), class: 'text-decoration-none fw-semibold' %>
                  <% if post.excerpt.present? %>
                    <br><small class="text-muted"><%= truncate(post.excerpt, length: 80) %></small>
                  <% end %>
                </td>
                <td>
                  <% case post.status %>
                  <% when 'draft' %>
                    <span class="badge bg-warning text-dark">Borrador</span>
                  <% when 'published' %>
                    <span class="badge bg-success">Publicado</span>
                  <% when 'archived' %>
                    <span class="badge bg-secondary">Archivado</span>
                  <% end %>
                </td>
                <td><small><%= post.author_name %></small></td>
                <td><small><%= post.published_at ? l(post.published_at.to_date, format: :long) : '—' %></small></td>
                <td><small><%= l post.updated_at.to_date, format: :long %></small></td>
                <td class="text-center">
                  <span class="badge bg-light text-dark border" title="Visitas registradas">
                    <i class="fas fa-eye text-muted me-1"></i><%= number_with_delimiter(post.views_count) %>
                  </span>
                </td>
                <td class="text-end pe-3">
                  <%= link_to edit_admin_post_path(post), class: 'btn btn-sm btn-outline-primary' do %>
                    <i class="fas fa-edit"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="p-3 border-top">
      <%= paginate @posts %>
    </div>
  </div>
<% else %>
  <div class="alert alert-light border text-center py-5">
    <i class="fas fa-newspaper fa-3x text-muted mb-3"></i>
    <h4 class="fw-semibold mb-2">Aún no hay publicaciones</h4>
    <p class="text-muted mb-3">Empieza a publicar contenido para mejorar el SEO orgánico de tu tienda.</p>
    <%= link_to new_admin_post_path, class: 'btn btn-danger' do %>
      <i class="fas fa-plus me-1"></i>Crear primera publicación
    <% end %>
  </div>
<% end %>
