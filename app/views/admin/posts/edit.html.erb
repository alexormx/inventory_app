<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
  <h2 class="mb-0"><i class="fas fa-pen-to-square text-primary me-2"></i>Editar publicación</h2>
  <div class="d-flex gap-2">
    <% if @post.published? %>
      <%= link_to post_path(@post), target: '_blank', class: 'btn btn-sm btn-outline-secondary' do %>
        <i class="fas fa-external-link-alt me-1"></i>Ver en sitio
      <% end %>
    <% end %>
    <% if @post.draft? || @post.archived? %>
      <%= button_to publish_admin_post_path(@post), method: :patch, class: 'btn btn-sm btn-success', form: { style: 'display:inline' } do %>
        <i class="fas fa-check me-1"></i>Publicar
      <% end %>
    <% else %>
      <%= button_to unpublish_admin_post_path(@post), method: :patch, class: 'btn btn-sm btn-warning', form: { style: 'display:inline' } do %>
        <i class="fas fa-eye-slash me-1"></i>Despublicar
      <% end %>
    <% end %>
    <%= button_to admin_post_path(@post), method: :delete,
                  class: 'btn btn-sm btn-outline-danger',
                  data: { turbo_confirm: '¿Eliminar definitivamente?' },
                  form: { style: 'display:inline' } do %>
      <i class="fas fa-trash"></i>
    <% end %>
  </div>
</div>
<%= render 'form', post: @post %>
