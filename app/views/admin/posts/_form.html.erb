<% content_for :head do %>
  <%= javascript_include_tag "richtext", "data-turbo-track": "reload", defer: true %>
<% end %>
<%= form_with model: [:admin, post], local: true, multipart: true, class: 'card border-0 shadow-sm' do |f| %>
  <div class="card-body d-flex flex-column gap-3">
    <% if post.errors.any? %>
      <div class="alert alert-danger mb-0">
        <strong>Hay errores que corregir:</strong>
        <ul class="mb-0 small">
          <% post.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :title, 'Título', class: 'form-label fw-semibold small' %>
      <%= f.text_field :title, class: 'form-control', required: true, maxlength: 200 %>
    </div>

    <div>
      <%= f.label :excerpt, 'Resumen', class: 'form-label fw-semibold small' %>
      <%= f.text_area :excerpt, class: 'form-control', rows: 3, maxlength: 500,
                      placeholder: '1-3 oraciones que se muestran en el listado del blog (también usado como descripción SEO si no llenas meta_description).' %>
      <div class="form-text small">Máximo 500 caracteres. Vacío para usar el inicio del cuerpo.</div>
    </div>

    <%# Editor con dos modos persistidos por post. El modo se guarda en
        post.editor_mode; al reabrir, el toggle y el contenido visible
        reflejan el modo con el que se guardó por última vez. %>
    <% html_mode = post.editor_html? %>
    <div data-controller="editor-mode">
      <%= f.label :body, 'Contenido', class: 'form-label fw-semibold small' %>

      <div class="btn-group btn-group-sm mb-2 d-flex" role="group" aria-label="Modo de edición">
        <input type="radio" class="btn-check" name="editor_mode_choice" id="editor_mode_wysiwyg" autocomplete="off" <%= 'checked' unless html_mode %>
               data-editor-mode-target="wysiwygRadio" data-action="change->editor-mode#switch">
        <label class="btn btn-outline-primary" for="editor_mode_wysiwyg">
          <i class="fas fa-eye me-1"></i>Editor visual (WYSIWYG)
        </label>

        <input type="radio" class="btn-check" name="editor_mode_choice" id="editor_mode_html" autocomplete="off" <%= 'checked' if html_mode %>
               data-editor-mode-target="htmlRadio" data-action="change->editor-mode#switch">
        <label class="btn btn-outline-primary" for="editor_mode_html">
          <i class="fas fa-code me-1"></i>HTML directo
        </label>
      </div>

      <%# Hidden field that submits the chosen mode. Stimulus keeps it
          in sync with the radio above. The backend ONLY honors
          body_html_raw when this is 'html', preventing the WYSIWYG
          mode from accidentally getting overwritten. %>
      <%= f.hidden_field :editor_mode, value: (html_mode ? 'html' : 'wysiwyg'), data: { editor_mode_target: 'modeInput' } %>

      <%# WYSIWYG pane %>
      <div data-editor-mode-target="wysiwygPane" <%= 'hidden' if html_mode %>>
        <%= f.rich_text_area :body, class: 'trix-content' %>
        <div class="form-text small mt-1 text-muted">
          Edita con la barra de herramientas (negrita, listas, enlaces, imágenes…).
        </div>
      </div>

      <%# HTML pane. Pre-rellena con el HTML guardado cuando el post está
          en modo html, así puedes editarlo como código. %>
      <div data-editor-mode-target="htmlPane" <%= 'hidden' unless html_mode %>>
        <%= f.text_area :body_html_raw,
                        rows: 18,
                        value: (html_mode ? post.body_inner_html : ''),
                        class: 'form-control font-monospace',
                        style: 'font-size: .82rem; line-height: 1.55;',
                        placeholder: %(<h2>Subtítulo</h2>\n<p>Texto con <strong>negrita</strong> y <a href="https://...">enlace</a>.</p>\n<table>\n  <thead><tr><th>Columna A</th><th>Columna B</th></tr></thead>\n  <tbody><tr><td>1</td><td>2</td></tr></tbody>\n</table>\n<ul><li>Lista</li></ul>) %>
        <div class="alert alert-info small mt-2 mb-0">
          <i class="fas fa-info-circle me-1"></i>
          Al guardar, este HTML se conserva tal cual (con sanitización de tags peligrosos).
          La próxima vez que abras este post, seguirá en modo <strong>HTML directo</strong>
          y este textarea mostrará el HTML guardado para que puedas editarlo como código.
          Si cambias a <em>Editor visual</em>, Trix puede normalizar el formato.
        </div>
      </div>
    </div>

    <div>
      <%= f.label :cover_image, 'Imagen de portada', class: 'form-label fw-semibold small' %>
      <% if post.cover_image.attached? %>
        <div class="mb-2 d-flex align-items-center gap-2">
          <%= image_tag post.cover_image, style: 'max-width:160px; height:auto; border-radius:6px;', alt: '' %>
          <span class="small text-muted">Sube otra para reemplazarla</span>
        </div>
      <% end %>
      <%= f.file_field :cover_image, class: 'form-control', accept: 'image/*' %>
    </div>

    <div>
      <%= f.label :meta_description, 'Meta descripción (SEO)', class: 'form-label fw-semibold small' %>
      <%= f.text_area :meta_description, class: 'form-control', rows: 2, maxlength: 320,
                      placeholder: 'Lo que ve Google en los resultados. Si lo dejas vacío, se usa el resumen.' %>
      <div class="form-text small">Recomendado 150-160 caracteres.</div>
    </div>

    <div>
      <%= f.label :status, 'Estado', class: 'form-label fw-semibold small' %>
      <%= f.select :status, Post.statuses.keys.map { |k| [k.capitalize, k] }, {}, class: 'form-select' %>
    </div>

    <div class="d-flex justify-content-between align-items-center">
      <%= link_to 'Cancelar', admin_posts_path, class: 'btn btn-link text-muted' %>
      <%= f.submit (post.persisted? ? 'Guardar cambios' : 'Crear borrador'), class: 'btn btn-danger' %>
    </div>
  </div>
<% end %>
