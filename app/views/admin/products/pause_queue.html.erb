<div class="admin-page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <p class="admin-page-eyebrow mb-1">Catálogo</p>
    <h2 class="mb-0 d-flex align-items-center gap-2"><i class="fa-solid fa-pause"></i> Cola de revisión</h2>
    <p class="text-muted small mb-0 mt-1">Productos pausados automáticamente por falta de stock publicable. Revísalos y aprueba la republicación uno a uno.</p>
  </div>
  <%= link_to admin_products_path, class: "btn btn-sm btn-outline-secondary" do %>
    <i class="fa-solid fa-arrow-left me-1"></i>Volver a productos
  <% end %>
</div>

<div class="card mb-4">
  <div class="card-body py-2 d-flex flex-wrap align-items-center gap-3">
    <%= form_with url: pause_queue_admin_products_path, method: :get, local: true, class: "row g-2 align-items-center flex-grow-1" do %>
      <%= hidden_field_tag :filter, @filter if @filter.present? %>
      <div class="col-12 col-md-6">
        <div class="input-group input-group-sm">
          <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Buscar por nombre o SKU…", aria: { label: "Buscar productos pausados" } %>
          <%= submit_tag "Buscar", name: nil, class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>

    <div class="btn-group btn-group-sm ms-auto" role="group" aria-label="Filtrar cola de revisión">
      <%= link_to pause_queue_admin_products_path(q: @q.presence),
            class: "btn #{@filter == 'eligible' ? 'btn-outline-secondary' : 'btn-secondary'}" do %>
        Todos
      <% end %>
      <%= link_to pause_queue_admin_products_path(q: @q.presence, filter: 'eligible'),
            class: "btn #{@filter == 'eligible' ? 'btn-success' : 'btn-outline-success'}" do %>
        <i class="fa-solid fa-check me-1"></i>Aprobables<%= " (#{@eligible_count})" if @eligible_count %>
      <% end %>
    </div>
  </div>
</div>

<% if @products.empty? %>
  <div class="alert alert-success d-flex align-items-center gap-2" role="alert">
    <i class="fa-solid fa-circle-check"></i>
    No hay productos pausados en espera de revisión.
  </div>
<% else %>
  <div class="row">
    <% @products.each do |product| %>
      <% publishable = @publishable_counts[product.id].to_i %>
      <div class="col-12 col-md-6 col-lg-4 mb-3">
        <div class="card shadow-sm h-100 product-card">
          <div class="card-body d-flex flex-column">
            <div class="d-flex align-items-center mb-2">
              <div class="me-2">
                <% if product.product_images.attached? %>
                  <%= image_tag product.primary_product_image.variant(resize_to_fill: [64, 64]), class: "img-thumbnail" %>
                <% else %>
                  <%= image_tag "placeholder.png", class: "img-thumbnail", size: "64x64" %>
                <% end %>
              </div>
              <div class="flex-grow-1">
                <strong class="product-title line-clamp-1"><%= product.product_name %></strong><br>
                <span class="text-muted small">SKU: <%= product.product_sku %></span>
              </div>
            </div>

            <div class="mb-2 small text-muted">
              <i class="fa-solid fa-clock me-1"></i>
              Pausado <%= product.auto_paused_at ? "#{time_ago_in_words(product.auto_paused_at)} atrás" : "—" %>
            </div>

            <%# Señal de stock: distingue listos para despausar vs. aún sin stock %>
            <div class="mb-3">
              <% if publishable > 0 %>
                <span class="badge bg-success">
                  <i class="fa-solid fa-box me-1"></i><%= publishable %> pieza<%= 's' if publishable != 1 %> publicable<%= 's' if publishable != 1 %>
                </span>
              <% elsif product.preorder_available || product.backorder_allowed %>
                <span class="badge bg-info text-dark">
                  <i class="fa-solid fa-clock-rotate-left me-1"></i>
                  <%= product.preorder_available ? 'Preventa' : 'Backorder' %> habilitado
                </span>
              <% else %>
                <span class="badge bg-secondary">
                  <i class="fa-solid fa-ban me-1"></i>Sin stock publicable
                </span>
              <% end %>
            </div>

            <div class="mt-auto d-flex gap-2">
              <% if product.eligible_for_publication? %>
                <%= button_to resume_admin_product_path(product, page: params[:page], q: @q.presence, filter: @filter), method: :patch,
                      class: "btn btn-sm btn-success flex-grow-1" do %>
                  <i class="fa-solid fa-check me-1"></i>Aprobar y republicar
                <% end %>
              <% else %>
                <button type="button" class="btn btn-sm btn-success flex-grow-1" disabled
                        title="Habilita preventa/backorder o espera a que entre stock">
                  <i class="fa-solid fa-check me-1"></i>Aprobar y republicar
                </button>
              <% end %>
              <%= link_to edit_admin_product_path(product), class: "btn btn-sm btn-outline-primary", title: "Editar" do %>
                <i class="fa-solid fa-pen-to-square"></i>
              <% end %>
              <%= link_to admin_product_path(product), class: "btn btn-sm btn-outline-success", title: "Ver detalle" do %>
                <i class="fa-solid fa-eye"></i>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-3">
    <%= paginate @products %>
  </div>
<% end %>
