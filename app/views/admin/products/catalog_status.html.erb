<div class="admin-page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <p class="admin-page-eyebrow mb-1">Productos</p>
    <h2 class="mb-0"><i class="fa-solid fa-link me-2"></i>Estado de vinculación con catálogo</h2>
  </div>
  <div>
    <%= link_to admin_products_path, class: "btn btn-outline-secondary" do %>
      <i class="fa-solid fa-arrow-left me-1"></i> Volver a productos
    <% end %>
  </div>
</div>

<%# ── Contadores vinculación ── %>
<div class="row g-3 mb-3">
  <div class="col-md-4">
    <%= link_to catalog_status_admin_products_path(linked: nil, barcode_match: nil, supplier_code_match: nil, q: @q, sort: @sort), class: "card border-0 shadow-sm text-decoration-none #{'border-start border-primary border-3' if @link_filter.blank? && @barcode_filter.blank? && @supplier_code_filter.blank?}" do %>
      <div class="card-body text-center">
        <div class="fs-2 fw-bold text-dark"><%= @total %></div>
        <div class="text-muted small">Total productos</div>
      </div>
    <% end %>
  </div>
  <div class="col-md-4">
    <%= link_to catalog_status_admin_products_path(linked: "yes", barcode_match: nil, supplier_code_match: nil, q: @q, sort: @sort), class: "card border-0 shadow-sm text-decoration-none #{'border-start border-success border-3' if @link_filter == 'yes' && @barcode_filter.blank? && @supplier_code_filter.blank?}" do %>
      <div class="card-body text-center">
        <div class="fs-2 fw-bold text-success"><%= @linked %></div>
        <div class="text-muted small">Vinculados</div>
      </div>
    <% end %>
  </div>
  <div class="col-md-4">
    <%= link_to catalog_status_admin_products_path(linked: "no", barcode_match: nil, supplier_code_match: nil, q: @q, sort: @sort), class: "card border-0 shadow-sm text-decoration-none #{'border-start border-warning border-3' if @link_filter == 'no'}" do %>
      <div class="card-body text-center">
        <div class="fs-2 fw-bold text-warning"><%= @unlinked %></div>
        <div class="text-muted small">Sin vincular</div>
      </div>
    <% end %>
  </div>
</div>

<%# ── Contadores código de barras (solo vinculados) ── %>
<div class="row g-3 mb-3">
  <div class="col-md-4">
    <%= link_to catalog_status_admin_products_path(linked: "yes", barcode_match: "match", supplier_code_match: @supplier_code_filter.presence, q: @q, sort: @sort), class: "card border-0 shadow-sm text-decoration-none #{'border-start border-success border-3' if @barcode_filter == 'match'}" do %>
      <div class="card-body text-center">
        <div class="fs-4 fw-bold text-success"><i class="fa-solid fa-barcode me-1"></i><%= @barcode_match %></div>
        <div class="text-muted small">Barcode coincide</div>
      </div>
    <% end %>
  </div>
  <div class="col-md-4">
    <%= link_to catalog_status_admin_products_path(linked: "yes", barcode_match: "mismatch", supplier_code_match: @supplier_code_filter.presence, q: @q, sort: @sort), class: "card border-0 shadow-sm text-decoration-none #{'border-start border-danger border-3' if @barcode_filter == 'mismatch'}" do %>
      <div class="card-body text-center">
        <div class="fs-4 fw-bold text-danger"><i class="fa-solid fa-barcode me-1"></i><%= @barcode_mismatch %></div>
        <div class="text-muted small">Barcode diferente</div>
      </div>
    <% end %>
  </div>
  <div class="col-md-4">
    <%= link_to catalog_status_admin_products_path(linked: "yes", barcode_match: "no_barcode", supplier_code_match: @supplier_code_filter.presence, q: @q, sort: @sort), class: "card border-0 shadow-sm text-decoration-none #{'border-start border-secondary border-3' if @barcode_filter == 'no_barcode'}" do %>
      <div class="card-body text-center">
        <div class="fs-4 fw-bold text-secondary"><i class="fa-solid fa-barcode me-1"></i><%= @barcode_missing %></div>
        <div class="text-muted small">Sin barcode</div>
      </div>
    <% end %>
  </div>
</div>

<%# ── Contadores código de proveedor (solo vinculados) ── %>
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <%= link_to catalog_status_admin_products_path(linked: "yes", supplier_code_match: "match", barcode_match: @barcode_filter.presence, q: @q, sort: @sort), class: "card border-0 shadow-sm text-decoration-none #{'border-start border-success border-3' if @supplier_code_filter == 'match'}" do %>
      <div class="card-body text-center">
        <div class="fs-4 fw-bold text-success"><i class="fa-solid fa-hashtag me-1"></i><%= @supplier_code_match %></div>
        <div class="text-muted small">Cód. proveedor coincide</div>
      </div>
    <% end %>
  </div>
  <div class="col-md-4">
    <%= link_to catalog_status_admin_products_path(linked: "yes", supplier_code_match: "mismatch", barcode_match: @barcode_filter.presence, q: @q, sort: @sort), class: "card border-0 shadow-sm text-decoration-none #{'border-start border-danger border-3' if @supplier_code_filter == 'mismatch'}" do %>
      <div class="card-body text-center">
        <div class="fs-4 fw-bold text-danger"><i class="fa-solid fa-hashtag me-1"></i><%= @supplier_code_mismatch %></div>
        <div class="text-muted small">Cód. proveedor diferente</div>
      </div>
    <% end %>
  </div>
  <div class="col-md-4">
    <%= link_to catalog_status_admin_products_path(linked: "yes", supplier_code_match: "no_code", barcode_match: @barcode_filter.presence, q: @q, sort: @sort), class: "card border-0 shadow-sm text-decoration-none #{'border-start border-secondary border-3' if @supplier_code_filter == 'no_code'}" do %>
      <div class="card-body text-center">
        <div class="fs-4 fw-bold text-secondary"><i class="fa-solid fa-hashtag me-1"></i><%= @supplier_code_missing %></div>
        <div class="text-muted small">Sin cód. proveedor</div>
      </div>
    <% end %>
  </div>
</div>

<%# ── Filtros ── %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: catalog_status_admin_products_path, method: :get, local: true, class: "row g-2 align-items-end" do %>
      <div class="col-md-3">
        <label class="form-label small text-muted">Buscar</label>
        <input type="text" name="q" value="<%= @q %>" class="form-control" placeholder="Nombre o SKU...">
      </div>
      <div class="col-md-2">
        <label class="form-label small text-muted">Ordenar</label>
        <select name="sort" class="form-select">
          <option value="name_asc" <%= "selected" if @sort == "name_asc" %>>Nombre A-Z</option>
          <option value="name_desc" <%= "selected" if @sort == "name_desc" %>>Nombre Z-A</option>
          <option value="sku" <%= "selected" if @sort == "sku" %>>SKU</option>
          <option value="recent" <%= "selected" if @sort == "recent" %>>Más recientes</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small text-muted">Vinculación</label>
        <select name="linked" class="form-select">
          <option value="">Todos</option>
          <option value="yes" <%= "selected" if @link_filter == "yes" %>>Vinculados</option>
          <option value="no" <%= "selected" if @link_filter == "no" %>>Sin vincular</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small text-muted">Barcode</label>
        <select name="barcode_match" class="form-select">
          <option value="">Todos</option>
          <option value="match" <%= "selected" if @barcode_filter == "match" %>>Coincide</option>
          <option value="mismatch" <%= "selected" if @barcode_filter == "mismatch" %>>Diferente</option>
          <option value="no_barcode" <%= "selected" if @barcode_filter == "no_barcode" %>>Sin barcode</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small text-muted">Cód. proveedor</label>
        <select name="supplier_code_match" class="form-select">
          <option value="">Todos</option>
          <option value="match" <%= "selected" if @supplier_code_filter == "match" %>>Coincide</option>
          <option value="mismatch" <%= "selected" if @supplier_code_filter == "mismatch" %>>Diferente</option>
          <option value="no_code" <%= "selected" if @supplier_code_filter == "no_code" %>>Sin código</option>
        </select>
      </div>
      <div class="col-md-1">
        <button type="submit" class="btn btn-primary w-100"><i class="fa-solid fa-search"></i></button>
      </div>
    <% end %>
  </div>
</div>

<%# ── Tabla ── %>
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th style="width: 56px"></th>
            <th>Producto</th>
            <th>SKU</th>
            <th>Estado</th>
            <th>Catálogo vinculado</th>
            <th class="text-center">Similitud</th>
            <th class="text-center">Barcode</th>
            <th class="text-center">Cód. proveedor</th>
            <th style="width: 80px"></th>
          </tr>
        </thead>
        <tbody>
          <% @products.each do |product| %>
            <% catalog = product.supplier_catalog_item %>
            <tr>
              <td>
                <% if product.product_images.attached? %>
                  <%= image_tag product.product_images.first, class: "rounded", style: "width: 40px; height: 40px; object-fit: cover;" %>
                <% else %>
                  <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <i class="fa-solid fa-image text-muted"></i>
                  </div>
                <% end %>
              </td>
              <td>
                <strong><%= product.product_name %></strong>
                <% if product.brand.present? %>
                  <br><span class="text-muted small"><%= product.brand %></span>
                <% end %>
              </td>
              <td><code><%= product.product_sku %></code></td>
              <td>
                <% if product.status == "active" %>
                  <span class="badge bg-success">Activo</span>
                <% elsif product.status == "draft" %>
                  <span class="badge bg-secondary">Borrador</span>
                <% else %>
                  <span class="badge bg-warning text-dark">Inactivo</span>
                <% end %>
                <% if product.discontinued? %>
                  <span class="badge bg-danger">Discontinuado</span>
                <% end %>
              </td>
              <td>
                <% if catalog %>
                  <div>
                    <%= link_to admin_supplier_catalog_item_path(catalog), class: "text-decoration-none" do %>
                      <i class="fa-solid fa-link text-success me-1"></i>
                      <span class="text-break"><%= catalog.canonical_name %></span>
                    <% end %>
                  </div>
                  <div class="text-muted small"><%= catalog.external_sku %></div>
                <% else %>
                  <span class="text-muted"><i class="fa-solid fa-link-slash me-1"></i> Sin vincular</span>
                <% end %>
              </td>
              <td class="text-center">
                <% if catalog %>
                  <% score = name_similarity_score(catalog.canonical_name, product.product_name) %>
                  <%= similarity_badge(score) %>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td class="text-center">
                <% if catalog %>
                  <% p_bc = product.barcode.presence %>
                  <% c_bc = catalog.barcode.presence %>
                  <% if p_bc && c_bc && p_bc == c_bc %>
                    <span class="badge bg-success" title="<%= p_bc %>"><i class="fa-solid fa-check me-1"></i>Coincide</span>
                  <% elsif p_bc && c_bc && p_bc != c_bc %>
                    <span class="badge bg-danger" title="Producto: <%= p_bc %> | Catálogo: <%= c_bc %>">
                      <i class="fa-solid fa-xmark me-1"></i>Diferente
                    </span>
                  <% elsif p_bc.nil? && c_bc.nil? %>
                    <span class="badge bg-light text-muted">Sin barcode</span>
                  <% elsif p_bc.nil? %>
                    <span class="badge bg-warning text-dark" title="Catálogo: <%= c_bc %>">Falta en producto</span>
                  <% else %>
                    <span class="badge bg-warning text-dark" title="Producto: <%= p_bc %>">Falta en catálogo</span>
                  <% end %>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td class="text-center">
                <% if catalog %>
                  <% p_sc = product.supplier_product_code.presence %>
                  <% c_sc = catalog.supplier_product_code.presence %>
                  <% if p_sc && c_sc && p_sc == c_sc %>
                    <span class="badge bg-success" title="<%= p_sc %>"><i class="fa-solid fa-check me-1"></i>Coincide</span>
                  <% elsif p_sc && c_sc && p_sc != c_sc %>
                    <span class="badge bg-danger" title="Producto: <%= p_sc %> | Catálogo: <%= c_sc %>">
                      <i class="fa-solid fa-xmark me-1"></i>Diferente
                    </span>
                  <% elsif p_sc.nil? && c_sc.nil? %>
                    <span class="badge bg-light text-muted">Sin código</span>
                  <% elsif p_sc.nil? %>
                    <span class="badge bg-warning text-dark" title="Catálogo: <%= c_sc %>">Falta en producto</span>
                  <% else %>
                    <span class="badge bg-warning text-dark" title="Producto: <%= p_sc %>">Falta en catálogo</span>
                  <% end %>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td>
                <%= link_to admin_product_path(product), class: "btn btn-sm btn-outline-primary", title: "Ver producto" do %>
                  <i class="fa-solid fa-eye"></i>
                <% end %>
                <% if catalog %>
                  <%= link_to review_sync_admin_supplier_catalog_item_path(catalog), class: "btn btn-sm btn-outline-success", title: "Revisar sync" do %>
                    <i class="fa-solid fa-arrows-left-right"></i>
                  <% end %>
                <% else %>
                  <button type="button" class="btn btn-sm btn-outline-warning" title="Buscar en catálogo"
                    onclick="this.closest('tr').nextElementSibling.classList.toggle('d-none')">
                    <i class="fa-solid fa-search"></i>
                  </button>
                <% end %>
              </td>
            </tr>
            <%# Expandable search row for unlinked products %>
            <% unless catalog %>
              <tr class="d-none" id="search-row-<%= product.id %>">
                <td colspan="9" class="bg-light">
                  <div class="p-2" data-controller="catalog-item-search">
                    <div class="row align-items-start">
                      <div class="col-md-6">
                        <label class="form-label small fw-semibold mb-1">
                          <i class="fa-solid fa-magnifying-glass me-1"></i> Buscar artículo de catálogo para "<%= product.product_name %>"
                        </label>
                        <input type="text" class="form-control form-control-sm" placeholder="Nombre o SKU del catálogo..."
                          data-catalog-item-search-target="input" data-action="input->catalog-item-search#input" autocomplete="off">
                        <div class="list-group mt-1" data-catalog-item-search-target="results" style="max-height: 200px; overflow-y: auto;"></div>
                      </div>
                      <div class="col-md-6" id="catalog-selection-<%= product.id %>" style="display: none;">
                        <label class="form-label small fw-semibold mb-1">Artículo seleccionado</label>
                        <div class="alert alert-info py-2 px-3 mb-2 small d-flex align-items-center justify-content-between">
                          <div>
                            <i class="fa-solid fa-boxes-stacked me-1"></i>
                            <strong id="catalog-selected-name-<%= product.id %>"></strong>
                            <span class="text-muted ms-1" id="catalog-selected-sku-<%= product.id %>"></span>
                          </div>
                          <button type="button" class="btn btn-sm btn-outline-danger"
                            onclick="document.getElementById('catalog-selection-<%= product.id %>').style.display='none'">
                            <i class="fa-solid fa-xmark"></i>
                          </button>
                        </div>
                        <%= form_with url: link_catalog_admin_product_path(product), method: :post, local: true, class: "d-inline" do %>
                          <input type="hidden" name="catalog_item_id" id="catalog-item-id-<%= product.id %>">
                          <input type="hidden" name="return_filter" value="<%= @link_filter %>">
                          <input type="hidden" name="return_q" value="<%= @q %>">
                          <input type="hidden" name="return_sort" value="<%= @sort %>">
                          <input type="hidden" name="return_page" value="<%= params[:page] %>">
                          <button type="submit" class="btn btn-sm btn-success">
                            <i class="fa-solid fa-link me-1"></i> Vincular
                          </button>
                        <% end %>
                      </div>
                    </div>
                  </div>
                  <script>
                    document.querySelector('#search-row-<%= product.id %> [data-controller="catalog-item-search"]')
                      .addEventListener('catalog-item-search:selected', function(e) {
                        var item = e.detail;
                        document.getElementById('catalog-item-id-<%= product.id %>').value = item.id;
                        document.getElementById('catalog-selected-name-<%= product.id %>').textContent = item.canonical_name;
                        document.getElementById('catalog-selected-sku-<%= product.id %>').textContent = item.external_sku;
                        document.getElementById('catalog-selection-<%= product.id %>').style.display = '';
                      });
                  </script>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <% if @products.total_pages > 1 %>
    <div class="card-footer bg-white">
      <%= paginate @products %>
    </div>
  <% end %>
</div>
