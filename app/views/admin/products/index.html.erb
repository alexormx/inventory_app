<div class="admin-page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <p class="admin-page-eyebrow mb-1">Catálogo</p>
    <h2 class="mb-0 d-flex align-items-center gap-2"><i class="fa-solid fa-tags"></i> Productos</h2>
  </div>
  <span class="badge admin-page-badge">Gestiona borradores, productos activos y catálogo archivado</span>
</div>

<% missing_active_count = @shortcut_counts && @shortcut_counts[:active_missing].to_i %>
<% if missing_active_count.to_i > 0 %>
  <div class="alert alert-warning d-flex flex-wrap align-items-center gap-3 mb-4" role="alert">
    <div class="flex-grow-1">
      <strong><i class="fa-solid fa-triangle-exclamation me-2"></i>Atención:</strong>
      Hay <strong><%= missing_active_count %></strong> producto<%= 's' if missing_active_count != 1 %> publicado<%= 's' if missing_active_count != 1 %> sin ubicación física.
      Si te compran uno, no podrás localizarlo en bodega.
    </div>
    <%= link_to admin_products_path(status: "active", location: "missing"),
                 class: "btn btn-sm btn-warning fw-semibold" do %>
      <i class="fa-solid fa-arrow-right me-1"></i>Ver y ubicar
    <% end %>
  </div>
<% end %>

<%= render partial: "admin/shared/status_counters", locals: {
  wrapper_id: "products_counts_global",
  counts: @counts_global,
  items: [
    [:draft,    "Borradores",   "bg-secondary"],
    [:active,   "Activos",      "bg-success"],
    [:inactive, "Inactivos",    "bg-danger"],
  ],
  title: "Resumen",
  cta_label: "Nuevo producto",
  cta_path: new_admin_product_path
} %>

<%# Búsqueda y filtros (estilo Inventario) %>
<div class="card mb-4">
  <div class="card-body py-2">
    <%= form_with url: admin_products_path, method: :get, local: true, class: "row g-2 align-items-center" do %>
      <div class="col-12 col-md-4">
        <div class="input-group input-group-sm">
          <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Buscar por nombre o SKU…", aria: { label: "Buscar productos" } %>
          <button class="btn btn-outline-secondary btn-clear-search" type="button" title="Limpiar búsqueda">Limpiar</button>
          <button class="btn btn-primary" type="submit" name="commit" value="search" title="Buscar">Buscar</button>
        </div>
      </div>
      <div class="col-12 col-md-3">
        <% current_sort = params[:sort].presence || "recent" %>
        <div class="input-group input-group-sm">
          <label class="input-group-text" for="sort"><i class="fa-solid fa-sort"></i></label>
          <%= select_tag :sort, options_for_select([
            ["Más recientes", "recent"],
            ["Más antiguos", "oldest"],
            ["Nombre A-Z", "name_asc"],
            ["Nombre Z-A", "name_desc"],
            ["SKU", "sku"],
            ["Precio ↑", "price_asc"],
            ["Precio ↓", "price_desc"],
            ["Stock ↑", "stock_asc"],
            ["Stock ↓", "stock_desc"],
            ["Más vendidos", "sales_value"],
            ["Mayor ganancia", "profit"]
          ], current_sort), class: "form-select form-select-sm", onchange: "this.form.submit()" %>
        </div>
      </div>
      <div class="col-12 col-md-5 text-md-end">
        <% current_status = params[:status].presence || "all" %>
        <% current_location = params[:location].presence || "all" %>
        <% outline_for = ->(st) do
             case st
             when "draft" then "secondary"
             when "active" then "success"
             when "inactive" then "danger"
             else "secondary"
             end
           end %>
        <% btnc = ->(st, cur) { ["btn", "btn-outline-#{outline_for.call(st)}", (cur == st ? "active" : nil)].compact.join(" ") } %>
        <div class="btn-group btn-group-sm me-2" role="group" aria-label="Filtro de status de producto">
          <%= button_tag "Todos", name: :status, value: "all", class: btnc.call("all", current_status) %>
          <%= button_tag "Borradores", name: :status, value: "draft", class: btnc.call("draft", current_status) %>
          <%= button_tag "Activos", name: :status, value: "active", class: btnc.call("active", current_status) %>
          <%= button_tag "Inactivos", name: :status, value: "inactive", class: btnc.call("inactive", current_status) %>
        </div>
        <%= link_to queue_admin_product_enrichment_index_path, class: "btn btn-sm btn-outline-warning ms-2", title: "Ver productos sin descripción" do %>
          <i class="fa-solid fa-wand-magic-sparkles me-1"></i>Sin descripción (<%= Product.without_description.count %>)
        <% end %>
        <%= hidden_field_tag :status, current_status %>
        <%= hidden_field_tag :location, current_location %>
        <% if ActiveModel::Type::Boolean.new.cast(params[:with_stock]) %>
          <%= hidden_field_tag :with_stock, "1" %>
        <% end %>
        <%= link_to "Limpiar", admin_products_path, class: "btn btn-sm btn-outline-secondary ms-2", title: "Quitar búsqueda y status" %>
      </div>

      <%# Filtro por ubicación física + atajos rápidos %>
      <% loc_btn = ->(loc) { ["btn", "btn-outline-primary", (current_location == loc ? "active" : nil)].compact.join(" ") } %>
      <% with_stock_active = ActiveModel::Type::Boolean.new.cast(params[:with_stock]) %>
      <% shortcut_active_missing = (current_status == "active" && current_location == "missing") %>
      <% shortcut_draftinactive_present = (current_status == "draft_or_inactive" && current_location == "present" && !with_stock_active) %>
      <% shortcut_draftinactive_present_stock = (current_status == "draft_or_inactive" && current_location == "present" && with_stock_active) %>
      <div class="col-12 d-flex flex-wrap align-items-center gap-2 mt-2">
        <span class="small text-muted me-1"><i class="fa-solid fa-location-dot me-1"></i>Ubicación:</span>
        <div class="btn-group btn-group-sm" role="group" aria-label="Filtro por ubicación física">
          <%= link_to "Todas", admin_products_path(request.query_parameters.merge(location: nil, page: nil).compact_blank),
                       class: loc_btn.call("all"), title: "Todos los productos" %>
          <%= link_to admin_products_path(request.query_parameters.merge(location: "missing", page: nil).compact_blank),
                       class: loc_btn.call("missing"), title: "Productos con stock físico sin ubicación asignada" do %>
            Sin ubicación
            <% if @location_counts && @location_counts[:missing].to_i > 0 %>
              <span class="badge bg-danger ms-1"><%= @location_counts[:missing] %></span>
            <% end %>
          <% end %>
          <%= link_to admin_products_path(request.query_parameters.merge(location: "present", page: nil).compact_blank),
                       class: loc_btn.call("present"), title: "Productos con ubicación física confirmada" do %>
            Con ubicación
            <% if @location_counts && @location_counts[:present].to_i > 0 %>
              <span class="badge bg-success ms-1"><%= @location_counts[:present] %></span>
            <% end %>
          <% end %>
        </div>

        <span class="vr mx-1"></span>
        <span class="small text-muted me-1">Atajos:</span>
        <%= link_to admin_products_path(q: @q, sort: @sort, status: "active", location: "missing"),
                     class: ["btn", "btn-sm", (shortcut_active_missing ? "btn-warning" : "btn-outline-warning")].join(" "),
                     title: "Productos activos a los que les falta ubicación física" do %>
          <i class="fa-solid fa-triangle-exclamation me-1"></i>Activos sin ubicación
          <% if @shortcut_counts && @shortcut_counts[:active_missing].to_i > 0 %>
            <span class="badge bg-light text-dark ms-1"><%= @shortcut_counts[:active_missing] %></span>
          <% end %>
        <% end %>
        <%= link_to admin_products_path(q: @q, sort: @sort, status: "draft_or_inactive", location: "present"),
                     class: ["btn", "btn-sm", (shortcut_draftinactive_present ? "btn-info" : "btn-outline-info")].join(" "),
                     title: "Productos en borrador o inactivos que ya tienen ubicación; candidatos a publicar" do %>
          <i class="fa-solid fa-rocket me-1"></i>Borrador/Inactivos con ubicación
          <% if @shortcut_counts && @shortcut_counts[:draft_or_inactive_present].to_i > 0 %>
            <span class="badge bg-light text-dark ms-1"><%= @shortcut_counts[:draft_or_inactive_present] %></span>
          <% end %>
        <% end %>
        <%= link_to admin_products_path(q: @q, sort: @sort, status: "draft_or_inactive", location: "present", with_stock: 1),
                     class: ["btn", "btn-sm", (shortcut_draftinactive_present_stock ? "btn-success" : "btn-outline-success")].join(" "),
                     title: "Borrador/Inactivos con ubicación Y al menos una pieza disponible — listos para publicar" do %>
          <i class="fa-solid fa-circle-check me-1"></i>Listos para publicar
          <% if @shortcut_counts && @shortcut_counts[:draft_or_inactive_present_stock].to_i > 0 %>
            <span class="badge bg-light text-dark ms-1"><%= @shortcut_counts[:draft_or_inactive_present_stock] %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# Contadores inferiores (dependen de búsqueda+status; ocultar cero) %>
<%= render partial: "admin/shared/status_counters", locals: {
  wrapper_id: "products_counts_filtered",
  counts: @counts,
  items: [
    [:draft,    "Borradores", "bg-secondary"],
    [:active,   "Activos",    "bg-success"],
    [:inactive, "Inactivos",  "bg-danger"],
  ],
  hide_zero: true,
  extra_class: "mb-2",
  title: "Resultados"
} %>

<div id="products_section">
  <%= render partial: 'products_section', locals: { products: @products, current_tab: (params[:status] || 'all'), inventory_counts: @inventory_counts } %>
</div>