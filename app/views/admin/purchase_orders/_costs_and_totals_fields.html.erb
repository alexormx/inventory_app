<%# Parcial: Campos de costos adicionales y totales %>
<div class="col-12">
  <div class="admin-order-section-intro admin-order-section-intro--soft">
    <div>
      <p class="admin-order-section-eyebrow mb-1">Costeo</p>
      <h6 class="admin-order-section-title mb-1"><i class="fa-solid fa-dollar-sign me-2"></i>Costos adicionales y totales</h6>
      <p class="admin-order-section-copy mb-0">Centraliza moneda, tipo de cambio y gastos extra para calcular el costo real de la compra.</p>
    </div>
  </div>
</div>

<div class="col-md-3">
  <%= f.label :currency, "Moneda", class: "form-label" %>
  <div class="input-group">
    <%= f.select :currency,
        PurchaseOrder::CURRENCIES.map { |c| [c, c] },
        {},
        class: "form-select" %>
    <span class="input-group-text"><i class="fa-solid fa-coins"></i></span>
  </div>
</div>

<div class="col-md-3">
  <%= f.label :exchange_rate, "Tipo de Cambio", class: "form-label" %>
  <div class="input-group">
    <span class="input-group-text" id="exchange-rate-left-label">1 <%= purchase_order.currency || "USD" %> =</span>
    <%= f.number_field :exchange_rate,
        step: 0.0001,
        class: "form-control text-end",
        placeholder: "17.5000" %>
    <span class="input-group-text">MXN</span>
  </div>
  <div class="form-text">
    <i class="fa-solid fa-circle-info"></i> Tipo de cambio a pesos mexicanos
  </div>
</div>

<div class="col-md-2">
  <%= f.label :shipping_cost, "Envío", class: "form-label" %>
  <div class="input-group input-group-sm">
    <span class="input-group-text"><i class="fa-solid fa-truck-fast"></i></span>
    <%= f.number_field :shipping_cost,
        step: 0.01,
        class: "form-control" %>
  </div>
</div>

<div class="col-md-2">
  <%= f.label :tax_cost, "Impuestos", class: "form-label" %>
  <div class="input-group input-group-sm">
    <span class="input-group-text"><i class="fa-solid fa-receipt"></i></span>
    <%= f.number_field :tax_cost,
        step: 0.01,
        class: "form-control" %>
  </div>
</div>

<div class="col-md-2">
  <%= f.label :other_cost, "Otros", class: "form-label" %>
  <div class="input-group input-group-sm">
    <span class="input-group-text"><i class="fa-solid fa-ellipsis"></i></span>
    <%= f.number_field :other_cost,
        step: 0.01,
        class: "form-control" %>
  </div>
</div>

<div class="col-12 mt-4">
  <div class="row g-3">
    <div class="col-md-3">
      <div class="admin-order-metric admin-order-metric--highlight">
        <div class="admin-order-metric-label">Subtotal de productos</div>
        <div class="admin-order-metric-value" id="display-subtotal">
          <%= number_to_currency(purchase_order.subtotal, precision: 2) %>
        </div>
        <div class="admin-order-metric-note">Solo productos base</div>
      </div>
    </div>

    <div class="col-md-2">
      <div class="admin-order-metric admin-order-metric--muted">
        <div class="admin-order-metric-label">Volumen total</div>
        <div class="admin-order-metric-value admin-order-metric-value--compact" id="display-volume">
          <%= number_with_precision(purchase_order.total_volume, precision: 2) %>
        </div>
        <div class="admin-order-metric-note">cm³</div>
      </div>
    </div>

    <div class="col-md-2">
      <div class="admin-order-metric admin-order-metric--muted">
        <div class="admin-order-metric-label">Peso total</div>
        <div class="admin-order-metric-value admin-order-metric-value--compact" id="display-weight">
          <%= number_with_precision(purchase_order.total_weight, precision: 2) %>
        </div>
        <div class="admin-order-metric-note">gr</div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="admin-order-metric admin-order-metric--success">
        <div class="admin-order-metric-label">Total de la orden</div>
        <div class="admin-order-metric-value admin-order-metric-value--strong" id="display-total">
          <%= number_to_currency(purchase_order.total_order_cost, precision: 2) %>
        </div>
        <div class="admin-order-metric-note">Incluye todos los extras</div>
      </div>
    </div>

    <div class="col-md-2">
      <div class="admin-order-metric admin-order-metric--muted">
        <div class="admin-order-metric-label">Total en MXN</div>
        <div class="admin-order-metric-value admin-order-metric-value--accent" id="display-total-mxn">
          <%= number_to_currency(purchase_order.total_cost_mxn, unit: "$", precision: 2) %>
        </div>
        <div class="admin-order-metric-note">Pesos MX</div>
      </div>
    </div>
  </div>
</div>

<%# Hidden fields para que Rails reciba los valores %>
<%# IMPORTANTE: Necesitamos AMBOS - el field principal (para JS fieldByName) Y el hidden (para sync) %>
<%= f.hidden_field :subtotal %>
<%= f.hidden_field :total_volume %>
<%= f.hidden_field :total_weight %>
<%= f.hidden_field :total_order_cost, id: "total_order_cost" %>
<%= f.hidden_field :total_cost_mxn, id: "total_cost_mxn" %>
