<%# Parcial: Campos de proveedor y fechas %>
<% purchase_status_options = [["Pendiente", "Pending"], ["En tránsito", "In Transit"], ["Entregada", "Delivered"], ["Cancelada", "Canceled"]] %>

<div class="col-12">
  <div class="admin-order-section-intro">
    <div>
      <p class="admin-order-section-eyebrow mb-1">Abastecimiento</p>
      <h6 class="admin-order-section-title mb-1">Proveedor, estado y fechas clave</h6>
      <p class="admin-order-section-copy mb-0">Mantén alineados el proveedor responsable, el avance logístico y el calendario operativo de la orden.</p>
    </div>
  </div>
</div>

<div class="col-md-6">
  <%= f.label :user_id, "Proveedor", class: "form-label" %>
  <div data-controller="user-suggest" data-user-suggest-role-value="supplier" class="position-relative">
    <input type="text"
           class="form-control"
           data-user-suggest-target="input"
           placeholder="Empieza a escribir el nombre del proveedor..."
           value="<%= f.object.user&.name %>"
           data-action="input->user-suggest#input keydown->user-suggest#keydown">
    <%= f.hidden_field :user_id, data: { 'user-suggest-target': 'hidden' } %>
    <div class="form-text admin-order-field-note" data-user-suggest-target="hint">
      <i class="fa fa-info-circle"></i> Selecciona el proveedor de esta orden
    </div>
    <div data-user-suggest-target="results" class="admin-user-suggest-results"></div>
  </div>
</div>

<div class="col-md-6">
  <%= f.label :status, "Estado de la Orden", class: "form-label" %>
  <div class="input-group">
    <%= f.select :status,
        purchase_status_options,
        {},
        class: "form-select" %>
    <span class="input-group-text">
      <i class="fa fa-truck"></i>
    </span>
  </div>
  <div class="form-text admin-order-field-note">
    <i class="fa fa-info-circle"></i> El estado afecta el inventario automáticamente
  </div>
</div>

<div class="col-md-4">
  <%= f.label :order_date, "Fecha de Orden", class: "form-label" %>
  <div class="input-group">
    <span class="input-group-text"><i class="fa fa-calendar"></i></span>
    <%= f.date_field :order_date, class: "form-control" %>
  </div>
</div>

<div class="col-md-4">
  <%= f.label :expected_delivery_date, "Entrega Esperada", class: "form-label" %>
  <div class="input-group">
    <span class="input-group-text"><i class="fa fa-calendar-check"></i></span>
    <%= f.date_field :expected_delivery_date, class: "form-control" %>
  </div>
</div>

<div class="col-md-4">
  <%= f.label :actual_delivery_date, "Entrega Real", class: "form-label" %>
  <div class="input-group">
    <span class="input-group-text"><i class="fa fa-calendar-day"></i></span>
    <%= f.date_field :actual_delivery_date, class: "form-control", placeholder: "Dejar vacío si aún no se entrega" %>
  </div>
  <div class="form-text admin-order-field-note">
    <i class="fa fa-info-circle"></i> Completa este campo cuando la mercancía llegue físicamente al almacén.
  </div>
</div>

<div class="col-12">
  <%= f.label :notes, "Notas / Comentarios", class: "form-label" %>
  <%= f.text_area :notes, class: "form-control admin-order-textarea", rows: 3, placeholder: "Información adicional sobre la orden..." %>
</div>
