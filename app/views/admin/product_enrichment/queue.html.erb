<div class="admin-page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <p class="admin-page-eyebrow mb-1">IA › Enriquecimiento</p>
    <h2 class="mb-0 d-flex align-items-center gap-2"><i class="fa fa-list-check"></i> Productos sin descripción</h2>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_product_enrichment_index_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="fa fa-arrow-left me-1"></i> Dashboard
    <% end %>
  </div>
</div>

<%# Filtros %>
<div class="card mb-4">
  <div class="card-body py-2">
    <%= form_with url: queue_admin_product_enrichment_index_path, method: :get, local: true, class: "row g-2 align-items-center" do %>
      <div class="col-auto">
        <%= select_tag :brand, options_for_select([["Todas las marcas", ""]] + @brands.map { |b| [b, b] }, params[:brand]),
                       class: "form-select form-select-sm" %>
      </div>
      <div class="col-auto">
        <%= select_tag :category, options_for_select([["Todas las categorías", ""]] + @categories.map { |c| [c, c] }, params[:category]),
                       class: "form-select form-select-sm" %>
      </div>
      <div class="col-auto">
        <%= select_tag :sort, options_for_select([
          ["Prioridad (inventario + ubicación)", "priority"],
          ["Nombre A-Z", "name"],
          ["Más recientes", "newest"]
        ], params[:sort] || "priority"),
                       class: "form-select form-select-sm" %>
      </div>
      <div class="col-auto">
        <button class="btn btn-primary btn-sm" type="submit"><i class="fa fa-filter me-1"></i> Filtrar</button>
      </div>
      <div class="col-auto">
        <%= link_to "Limpiar", queue_admin_product_enrichment_index_path, class: "btn btn-outline-secondary btn-sm" %>
      </div>
    <% end %>
  </div>
</div>

<p class="text-muted mb-3"><%= @products.total_count %> productos sin descripción</p>

<% if @products.any? %>
  <div class="table-responsive">
    <table class="table table-hover table-sm">
      <thead class="table-light">
        <tr>
          <th>Producto</th>
          <th>Marca</th>
          <th>Categoría</th>
          <th class="text-center" title="Inventario disponible"><i class="fa fa-boxes-stacked"></i> Disp.</th>
          <th class="text-center" title="Con ubicación confirmada"><i class="fa fa-location-dot"></i> Ubic.</th>
          <th>Template</th>
          <th>Borrador</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td>
              <%= link_to product.product_name, admin_product_path(product), class: "text-decoration-none fw-semibold" %>
            </td>
            <td><%= product.brand %></td>
            <td><%= product.category %></td>
            <td class="text-center">
              <% avail = product.respond_to?(:available_count) ? product.available_count : 0 %>
              <% if avail > 0 %>
                <span class="badge bg-success"><%= avail %></span>
              <% else %>
                <span class="text-muted">0</span>
              <% end %>
            </td>
            <td class="text-center">
              <% loc = product.respond_to?(:located_count) ? product.located_count : 0 %>
              <% if loc > 0 %>
                <span class="badge bg-primary"><%= loc %></span>
              <% else %>
                <span class="text-muted">0</span>
              <% end %>
            </td>
            <td>
              <% if product.attribute_template %>
                <span class="badge bg-success"><i class="fa fa-check"></i></span>
              <% else %>
                <span class="badge bg-warning text-dark" title="Sin template para '#{product.category}'"><i class="fa fa-exclamation-triangle"></i></span>
              <% end %>
            </td>
            <td>
              <% current = product.current_draft %>
              <% if current %>
                <%= render_enrichment_status_badge(current.status) %>
              <% else %>
                <span class="text-muted">—</span>
              <% end %>
            </td>
            <td class="text-end">
              <% current = product.current_draft %>
              <% if current&.draft_generated? %>
                <%= link_to admin_product_enrichment_path(current), class: "btn btn-outline-primary btn-sm" do %>
                  <i class="fa fa-eye"></i> Revisar
                <% end %>
              <% elsif current&.queued? || current&.generating? %>
                <span class="btn btn-outline-secondary btn-sm disabled">
                  <i class="fa fa-spinner fa-spin"></i> Procesando
                </span>
              <% else %>
                <%= button_to generate_admin_product_enrichment_path(product), method: :post, class: "btn btn-primary btn-sm" do %>
                  <i class="fa fa-wand-magic-sparkles me-1"></i> Generar
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= paginate @products %>
<% else %>
  <div class="text-center py-5 text-muted">
    <i class="fa fa-check-circle fa-3x mb-3 d-block text-success"></i>
    <p>¡Todos los productos tienen descripción!</p>
  </div>
<% end %>
