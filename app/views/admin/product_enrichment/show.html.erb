<div class="admin-page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <p class="admin-page-eyebrow mb-1">IA › Enriquecimiento</p>
    <h2 class="mb-0 d-flex align-items-center gap-2">
      <i class="fa-solid fa-wand-magic-sparkles"></i>
      <%= @product.product_name %>
    </h2>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_product_enrichment_index_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="fa-solid fa-arrow-left me-1"></i> Dashboard
    <% end %>
    <%= link_to admin_product_path(@product), class: "btn btn-outline-secondary btn-sm" do %>
      <i class="fa-solid fa-box me-1"></i> Ver producto
    <% end %>
  </div>
</div>

<%# Estado del borrador %>
<div class="row mb-4">
  <div class="col-12">
    <div class="card border-0 shadow-sm">
      <div class="card-body py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="d-flex align-items-center gap-3">
          <%= render_enrichment_status_badge(@draft.status) %>
          <% if @draft.confidence_score %>
            <span class="badge <%= @draft.confidence_score >= 0.8 ? 'bg-success' : @draft.confidence_score >= 0.6 ? 'bg-warning text-dark' : 'bg-danger' %>">
              Confianza: <%= (@draft.confidence_score * 100).round %>%
            </span>
          <% end %>
          <% if @draft.ai_model %>
            <small class="text-muted"><i class="fa-solid fa-robot me-1"></i><%= @draft.ai_model %></small>
          <% end %>
          <% if @draft.total_tokens > 0 %>
            <small class="text-muted"><i class="fa-solid fa-coins me-1"></i><%= number_with_delimiter(@draft.total_tokens) %> tokens</small>
          <% end %>
          <% if @draft.estimated_cost_cents %>
            <small class="text-muted">~$<%= '%.4f' % @draft.estimated_cost_usd %> USD</small>
          <% end %>
        </div>
        <div class="d-flex gap-2">
          <% if @draft.draft_generated? %>
            <%= button_to publish_admin_product_enrichment_path(@draft), method: :post, class: "btn btn-success btn-sm",
                data: { turbo_confirm: "¿Publicar esta descripción y atributos al producto?" } do %>
              <i class="fa-solid fa-check me-1"></i> Publicar
            <% end %>
            <%= button_to regenerate_admin_product_enrichment_path(@draft), method: :post, class: "btn btn-outline-warning btn-sm" do %>
              <i class="fa-solid fa-rotate me-1"></i> Regenerar
            <% end %>
            <%= button_to reject_admin_product_enrichment_path(@draft), method: :post, class: "btn btn-outline-danger btn-sm",
                data: { turbo_confirm: "¿Rechazar este borrador?" } do %>
              <i class="fa-solid fa-xmark me-1"></i> Rechazar
            <% end %>
          <% elsif @draft.failed? %>
            <%= button_to regenerate_admin_product_enrichment_path(@draft), method: :post, class: "btn btn-warning btn-sm" do %>
              <i class="fa-solid fa-rotate me-1"></i> Reintentar
            <% end %>
          <% elsif @draft.queued? || @draft.generating? %>
            <span class="text-muted"><i class="fa-solid fa-spinner fa-spin me-1"></i> Generando...</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<% if @draft.failed? && @draft.error_message.present? %>
  <div class="alert alert-danger mb-4">
    <i class="fa-solid fa-triangle-exclamation me-1"></i>
    <strong>Error de generación:</strong> <%= @draft.error_message %>
  </div>
<% end %>

<% if @draft.warnings.present? && @draft.warnings.any? %>
  <div class="alert alert-warning mb-4">
    <i class="fa-solid fa-circle-exclamation me-1"></i>
    <strong>Advertencias de la IA:</strong>
    <ul class="mb-0 mt-1">
      <% @draft.warnings.each do |warning| %>
        <li><%= warning %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @draft, url: update_draft_admin_product_enrichment_path(@draft), method: :patch, local: true do |f| %>

  <%# SECCIÓN 1: Descripción %>
  <div class="row mb-4">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-light">
          <h6 class="mb-0"><i class="fa-solid fa-file-lines me-1"></i> Descripción actual</h6>
        </div>
        <div class="card-body">
          <% if @draft.original_description.present? %>
            <p style="white-space: pre-line;"><%= @draft.original_description %></p>
          <% else %>
            <p class="text-muted fst-italic">Sin descripción</p>
          <% end %>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 shadow-sm h-100 border-start border-primary border-3">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
          <h6 class="mb-0"><i class="fa-solid fa-wand-magic-sparkles me-1 text-primary"></i> Descripción propuesta</h6>
          <span class="badge bg-primary">IA</span>
        </div>
        <div class="card-body">
          <% if @draft.draft_generated? %>
            <%= f.text_area :draft_content, class: "form-control", rows: 10, style: "white-space: pre-line;" %>
          <% elsif @draft.draft_content.present? %>
            <p style="white-space: pre-line;"><%= @draft.draft_content %></p>
          <% else %>
            <p class="text-muted fst-italic">Pendiente de generación</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# SECCIÓN 2: Atributos %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
      <h6 class="mb-0"><i class="fa-solid fa-tags me-1"></i> Atributos del producto</h6>
      <% if @template %>
        <span class="badge bg-info">Template: <%= @template.category %> (<%= @template.attribute_keys.size %> atributos)</span>
      <% else %>
        <span class="badge bg-warning text-dark">Sin template para '<%= @product.category %>'</span>
      <% end %>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th style="width: 20%;">Atributo</th>
              <th style="width: 30%;">Valor actual</th>
              <th style="width: 30%;">Valor propuesto (IA)</th>
              <th style="width: 10%;">Tipo</th>
              <th style="width: 10%;">Req.</th>
            </tr>
          </thead>
          <tbody>
            <% original_attrs = @draft.original_attributes || {} %>
            <% draft_attrs = @draft.draft_attributes || {} %>
            <%
              # Collect all keys: from template (ordered) + any extras from draft
              if @template
                all_keys = @template.attributes_schema.map { |a| a["key"] }
                draft_attrs.keys.each { |k| all_keys << k unless all_keys.include?(k) }
              else
                all_keys = (original_attrs.keys + draft_attrs.keys).uniq
              end
            %>
            <% all_keys.each do |key| %>
              <% original_val = original_attrs[key] %>
              <% draft_val = draft_attrs[key] %>
              <% schema = @template&.schema_for(key) %>
              <% changed = original_val.to_s != draft_val.to_s %>
              <% is_new = original_val.blank? && draft_val.present? %>
              <tr class="<%= is_new ? 'table-success' : changed ? 'table-warning' : '' %>">
                <td class="fw-semibold">
                  <%= schema ? schema["label"] : key.humanize %>
                  <br><small class="text-muted"><%= key %></small>
                </td>
                <td>
                  <% if original_val.present? %>
                    <%= original_val %>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <td>
                  <% if @draft.draft_generated? %>
                    <%= f.text_field "draft_attributes[#{key}]", value: draft_val, class: "form-control form-control-sm" %>
                  <% else %>
                    <%= draft_val.present? ? draft_val : "—" %>
                  <% end %>
                </td>
                <td><small class="text-muted"><%= schema ? schema["type"] : "string" %></small></td>
                <td>
                  <% if schema && schema["required"] %>
                    <span class="badge bg-danger">Sí</span>
                  <% else %>
                    <small class="text-muted">No</small>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# Notas del admin + guardar %>
  <% if @draft.draft_generated? %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <div class="mb-3">
          <%= f.label :admin_notes, "Notas del admin (opcional)", class: "form-label" %>
          <%= f.text_area :admin_notes, class: "form-control", rows: 2, placeholder: "Notas internas sobre la revisión..." %>
        </div>
        <div class="d-flex justify-content-end gap-2">
          <%= f.submit "Guardar cambios al borrador", class: "btn btn-outline-primary" %>
        </div>
      </div>
    </div>
  <% end %>

<% end %>

<%# Highlights y SEO keywords del output %>
<% if @draft.structured_output.present? %>
  <div class="row mb-4">
    <% if @draft.structured_output["highlights"].present? %>
      <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-header bg-light">
            <h6 class="mb-0"><i class="fa-solid fa-star me-1 text-warning"></i> Highlights</h6>
          </div>
          <div class="card-body">
            <ul class="mb-0">
              <% @draft.structured_output["highlights"].each do |h| %>
                <li><%= h %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>
    <% if @draft.structured_output["seo_keywords"].present? %>
      <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-header bg-light">
            <h6 class="mb-0"><i class="fa-solid fa-magnifying-glass me-1 text-info"></i> Keywords SEO</h6>
          </div>
          <div class="card-body">
            <% @draft.structured_output["seo_keywords"].each do |kw| %>
              <span class="badge bg-light text-dark border me-1 mb-1"><%= kw %></span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<%# Historial de borradores %>
<% if @history.size > 1 %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-light">
      <h6 class="mb-0"><i class="fa-solid fa-clock-rotate-left me-1"></i> Historial de borradores (<%= @history.size %>)</h6>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm mb-0">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Estado</th>
              <th>Confianza</th>
              <th>Modelo</th>
              <th>Fecha</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @history.each_with_index do |d, i| %>
              <tr class="<%= d.id == @draft.id ? 'table-active' : '' %>">
                <td><%= @history.size - i %></td>
                <td><%= render_enrichment_status_badge(d.status) %></td>
                <td><%= d.confidence_score ? "#{(d.confidence_score * 100).round}%" : "—" %></td>
                <td><small><%= d.ai_model || "—" %></small></td>
                <td><small><%= l(d.created_at, format: :short) %></small></td>
                <td>
                  <% if d.id != @draft.id %>
                    <%= link_to admin_product_enrichment_path(d), class: "btn btn-outline-secondary btn-sm" do %>
                      <i class="fa-solid fa-eye"></i>
                    <% end %>
                  <% else %>
                    <span class="badge bg-primary">Actual</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>
