<%# Form for creating/editing CategoryAttributeTemplate %>
<%= form_with model: template, url: template.persisted? ? admin_category_attribute_template_path(template) : admin_category_attribute_templates_path,
              method: template.persisted? ? :patch : :post, local: true do |f| %>

  <% if template.errors.any? %>
    <div class="alert alert-danger mb-3">
      <ul class="mb-0">
        <% template.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :category, "Categoría", class: "form-label" %>
          <%= f.text_field :category, class: "form-control", placeholder: "ej. diecast", required: true %>
          <small class="text-muted">Debe coincidir exactamente con el campo 'category' de los productos (se normaliza a minúsculas).</small>
        </div>
        <div class="col-md-6">
          <div class="form-check mt-4 pt-2">
            <%= f.check_box :active, class: "form-check-input" %>
            <%= f.label :active, "Activo", class: "form-check-label" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
      <h6 class="mb-0"><i class="fa fa-list me-1"></i> Definición de atributos</h6>
      <small class="text-muted">Define los atributos que la IA debe generar para esta categoría</small>
    </div>
    <div class="card-body" data-controller="template-schema-editor">
      <%# Hidden field that stores the JSON schema %>
      <%= f.hidden_field :attributes_schema_json,
            value: template.attributes_schema.to_json,
            data: { template_schema_editor_target: "jsonField" } %>

      <div data-template-schema-editor-target="container">
        <% template.attributes_schema.each_with_index do |attr, index| %>
          <div class="row g-2 mb-2 align-items-center schema-row" data-index="<%= index %>">
            <div class="col-md-2">
              <input type="text" class="form-control form-control-sm" placeholder="key"
                     value="<%= attr['key'] %>" data-field="key" required>
            </div>
            <div class="col-md-2">
              <input type="text" class="form-control form-control-sm" placeholder="Label"
                     value="<%= attr['label'] %>" data-field="label">
            </div>
            <div class="col-md-1">
              <select class="form-select form-select-sm" data-field="type">
                <option value="string" <%= 'selected' if attr['type'] == 'string' %>>string</option>
                <option value="boolean" <%= 'selected' if attr['type'] == 'boolean' %>>boolean</option>
                <option value="date" <%= 'selected' if attr['type'] == 'date' %>>date</option>
              </select>
            </div>
            <div class="col-md-1 text-center">
              <div class="form-check d-inline-block">
                <input type="checkbox" class="form-check-input" data-field="required"
                       <%= 'checked' if attr['required'] %>>
                <label class="form-check-label small">Req.</label>
              </div>
            </div>
            <div class="col-md-1">
              <input type="number" class="form-control form-control-sm" placeholder="#"
                     value="<%= attr['position'] || index + 1 %>" data-field="position">
            </div>
            <div class="col-md-3">
              <input type="text" class="form-control form-control-sm" placeholder="Ejemplo..."
                     value="<%= attr['example'] %>" data-field="example">
            </div>
            <div class="col-md-2 text-end">
              <button type="button" class="btn btn-outline-danger btn-sm"
                      data-action="template-schema-editor#removeRow">
                <i class="fa fa-trash"></i>
              </button>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-3 d-flex gap-2">
        <button type="button" class="btn btn-outline-primary btn-sm"
                data-action="template-schema-editor#addRow">
          <i class="fa fa-plus me-1"></i> Agregar atributo
        </button>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-end gap-2">
    <%= link_to "Cancelar", admin_category_attribute_templates_path, class: "btn btn-outline-secondary" %>
    <%= f.submit template.persisted? ? "Actualizar template" : "Crear template", class: "btn btn-primary" %>
  </div>
<% end %>
