<div class="admin-page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <p class="admin-page-eyebrow mb-1">IA › Configuración</p>
    <h2 class="mb-0 d-flex align-items-center gap-2"><i class="fa fa-puzzle-piece"></i> Templates de Atributos</h2>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_product_enrichment_index_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="fa fa-arrow-left me-1"></i> Enriquecimiento
    <% end %>
    <%= link_to new_admin_category_attribute_template_path, class: "btn btn-primary btn-sm" do %>
      <i class="fa fa-plus me-1"></i> Nuevo template
    <% end %>
  </div>
</div>

<% if @categories_without_template.any? %>
  <div class="alert alert-warning mb-4">
    <i class="fa fa-exclamation-triangle me-1"></i>
    <strong>Categorías sin template:</strong>
    <% @categories_without_template.each do |cat| %>
      <%= link_to cat, new_admin_category_attribute_template_path(category: cat), class: "badge bg-warning text-dark text-decoration-none ms-1" %>
    <% end %>
  </div>
<% end %>

<% if @templates.any? %>
  <div class="row g-3">
    <% @templates.each do |template| %>
      <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0">
              <i class="fa fa-layer-group me-1"></i> <%= template.category.capitalize %>
            </h6>
            <% if template.active? %>
              <span class="badge bg-success">Activo</span>
            <% else %>
              <span class="badge bg-secondary">Inactivo</span>
            <% end %>
          </div>
          <div class="card-body">
            <p class="small text-muted mb-2"><%= template.attributes_schema.size %> atributos definidos</p>
            <div class="d-flex flex-wrap gap-1 mb-3">
              <% template.attributes_schema.each do |attr| %>
                <span class="badge <%= attr['required'] ? 'bg-primary' : 'bg-light text-dark border' %>" title="<%= attr['type'] %>">
                  <%= attr['label'] || attr['key'] %>
                </span>
              <% end %>
            </div>
          </div>
          <div class="card-footer bg-white border-top-0 d-flex gap-2">
            <%= link_to edit_admin_category_attribute_template_path(template), class: "btn btn-outline-primary btn-sm flex-grow-1" do %>
              <i class="fa fa-edit me-1"></i> Editar
            <% end %>
            <%= button_to admin_category_attribute_template_path(template), method: :delete,
                class: "btn btn-outline-danger btn-sm",
                data: { turbo_confirm: "¿Eliminar template '#{template.category}'?" } do %>
              <i class="fa fa-trash"></i>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-5 text-muted">
    <i class="fa fa-puzzle-piece fa-3x mb-3 d-block"></i>
    <p>No hay templates definidos.</p>
    <%= link_to new_admin_category_attribute_template_path, class: "btn btn-primary" do %>
      <i class="fa fa-plus me-1"></i> Crear primer template
    <% end %>
  </div>
<% end %>
