<div class="admin-page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <p class="admin-page-eyebrow mb-1">Proveedor</p>
    <h2 class="mb-0 d-flex align-items-center gap-2"><i class="fa-solid fa-cloud-arrow-down"></i> Descubrir nuevos productos en HLJ</h2>
    <p class="text-muted mb-0 mt-2">Configura filtros, consulta una vista previa y, si te convence, lanza la importación.</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_supplier_catalog_items_path, class: "btn btn-outline-secondary" do %>
      <i class="fa-solid fa-boxes-stacked me-1"></i> Ir a actualización y enriquecimiento
    <% end %>
  </div>
</div>

<%# ── Paso 1: Filtros + botón Vista previa ── %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <h5 class="mb-1"><span class="badge bg-primary me-2">1</span> Configura filtros</h5>
    <p class="text-muted mb-3">Define los criterios de búsqueda en HLJ. Nada se guarda hasta que tú lo indiques.</p>

    <%= form_with url: preview_discovery_admin_supplier_catalog_items_path, method: :post, data: { turbo: false }, class: "row g-3 align-items-end" do |f| %>
      <div class="col-12 col-md-2">
        <%= f.label :preset, "Preset", class: "form-label" %>
        <%= f.select :preset, options_for_select(@discovery_preset_options, @discovery_form[:preset]), {}, class: "form-select" %>
      </div>
      <div class="col-12 col-md-2">
        <%= f.label :word, "Search", class: "form-label" %>
        <%= f.text_field :word, value: @discovery_form[:word], class: "form-control", placeholder: "Ej. tomica premium" %>
      </div>
      <div class="col-12 col-md-4">
        <%= f.label "makers[]", "Manufacturer", class: "form-label" %>
        <%= select_tag "makers[]",
              options_for_select(@maker_options.map { |m| [m, m] }, @discovery_form[:makers]),
              multiple: true, class: "form-select", size: 4 %>
        <div class="form-text">Ctrl+click para seleccionar varios</div>
      </div>
      <div class="col-12 col-md-4">
        <%= f.label "genre_codes[]", "Category", class: "form-label" %>
        <%= select_tag "genre_codes[]",
              options_for_select(@genre_options.map { |g| [g, g] }, @discovery_form[:genre_codes]),
              multiple: true, class: "form-select", size: 4 %>
        <div class="form-text">Ctrl+click para seleccionar varias</div>
      </div>
      <div class="col-12 col-md-3">
        <%= f.label "scales[]", "Scale", class: "form-label" %>
        <%= select_tag "scales[]",
              options_for_select(@scale_options.map { |s| [s, s] }, @discovery_form[:scales]),
              multiple: true, class: "form-select", size: 4 %>
        <div class="form-text">Ctrl+click para seleccionar varias</div>
      </div>
      <div class="col-12 col-md-3">
        <%= f.label :series, "Series", class: "form-label" %>
        <%= f.text_field :series, value: @discovery_form[:series], class: "form-control", placeholder: "Ej. Tomica Premium" %>
      </div>
      <div class="col-6 col-md-2">
        <%= f.label :max_pages, "Máx. páginas", class: "form-label" %>
        <%= f.number_field :max_pages, value: @discovery_form[:max_pages], min: 1, class: "form-control", placeholder: "Todas" %>
      </div>
      <div class="col-6 col-md-2">
        <%= f.label :max_items, "Máx. productos", class: "form-label" %>
        <%= f.number_field :max_items, value: @discovery_form[:max_items], min: 1, class: "form-control", placeholder: "Todos" %>
      </div>
      <div class="col-12 col-md-2">
        <button type="submit" class="btn btn-outline-secondary" data-turbo-submits-with="Consultando HLJ…">
          <i class="fa-solid fa-magnifying-glass me-1"></i> Consultar vista previa
        </button>
      </div>
    <% end %>
  </div>
</div>

<%# ── Paso 2: Vista previa (solo si se consultó) ── %>
<% if @discovery_preview.present? %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <h5 class="mb-3"><span class="badge bg-primary me-2">2</span> Vista previa — resultados sin guardar</h5>

      <% if @discovery_preview.available_pages > @discovery_preview.scanned_pages %>
        <div class="alert alert-info py-2 mb-3">
          <i class="fa-solid fa-circle-info me-1"></i>
          Se consultaron <strong><%= @discovery_preview.scanned_pages %></strong> de <strong><%= @discovery_preview.available_pages %></strong> páginas disponibles en HLJ.
          La importación completa procesará todas las páginas.
        </div>
      <% end %>

      <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
          <div class="border rounded p-3 h-100">
            <small class="text-muted d-block">Productos encontrados (muestra)</small>
            <div class="fs-4 fw-bold"><%= @discovery_preview.total_found %></div>
            <div class="small text-muted">en <%= @discovery_preview.scanned_pages %> página(s) consultadas</div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="border rounded p-3 h-100">
            <small class="text-muted d-block">Páginas disponibles en HLJ</small>
            <div class="fs-4 fw-bold"><%= @discovery_preview.available_pages %></div>
            <div class="small text-muted">según la navegación detectada en HLJ</div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="border rounded p-3 h-100">
            <small class="text-muted d-block">Muestra visible</small>
            <div class="fs-4 fw-bold"><%= @discovery_preview.sample_items.size %></div>
            <div class="small text-muted">primeros <%= @discovery_preview.sample_limit %> resultados</div>
          </div>
        </div>
      </div>

      <% if @discovery_preview.sample_items.any? %>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th style="width: 60px">Imagen</th>
                <th>Artículo</th>
                <th>SKU externo</th>
                <th class="text-end">Precio (¥)</th>
                <th>Disponibilidad</th>
              </tr>
            </thead>
            <tbody>
              <% @discovery_preview.sample_items.each do |item| %>
                <tr>
                  <td>
                    <% if item[:listing_image_url].present? %>
                      <a href="<%= item[:listing_image_url] %>" target="_blank" rel="noopener">
                        <img src="<%= item[:listing_image_url] %>" alt="<%= item[:name] %>" style="width: 48px; height: 48px; object-fit: contain;" class="rounded border" loading="lazy">
                      </a>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                  <td>
                    <div class="fw-semibold"><%= item[:name] %></div>
                    <div class="small text-muted text-truncate" style="max-width: 320px;"><%= link_to item[:source_url], item[:source_url], target: "_blank", rel: "noopener" %></div>
                  </td>
                  <td><%= item[:external_sku] %></td>
                  <td class="text-end">
                    <% if item[:jpy_price].present? %>
                      <% if item[:jpy_special_price].present? && item[:jpy_special_price].to_i < item[:jpy_price].to_i %>
                        <span class="text-decoration-line-through text-muted small">¥<%= number_with_delimiter(item[:jpy_price]) %></span><br>
                        <span class="fw-bold text-danger">¥<%= number_with_delimiter(item[:jpy_special_price]) %></span>
                      <% else %>
                        <span class="fw-semibold">¥<%= number_with_delimiter(item[:jpy_price]) %></span>
                      <% end %>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                  <td>
                    <% if item[:stock_status].present? %>
                      <% badge_class = case item[:stock_status]
                           when "instock" then "bg-success"
                           when "futurerelease", "backorder" then "bg-info"
                           when "discontinued" then "bg-secondary"
                           when "orderstop" then "bg-warning text-dark"
                           else "bg-light text-dark"
                         end %>
                      <span class="badge <%= badge_class %>"><%= item[:availability] || item[:stock_status] %></span>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-muted mb-0">No se encontraron productos con esos filtros.</p>
      <% end %>

      <%# ── Paso 3: Ejecutar importación ── %>
      <div class="border-top mt-4 pt-4">
        <h5 class="mb-3"><span class="badge bg-success me-2">3</span> Ejecutar importación a base de datos</h5>
        <p class="text-muted mb-3">Los productos se importarán al catálogo proveedor. Elige corrida completa o prueba rápida.</p>
        <%= form_with url: run_discovery_admin_supplier_catalog_items_path, method: :post, local: true, class: "d-flex flex-wrap gap-2" do |f| %>
          <%= f.hidden_field :preset, value: @discovery_form[:preset] %>
          <%= f.hidden_field :word, value: @discovery_form[:word] %>
          <% Array(@discovery_form[:makers]).each do |maker| %>
            <input type="hidden" name="makers[]" value="<%= maker %>" />
          <% end %>
          <% Array(@discovery_form[:genre_codes]).each do |gc| %>
            <input type="hidden" name="genre_codes[]" value="<%= gc %>" />
          <% end %>
          <% Array(@discovery_form[:scales]).each do |s| %>
            <input type="hidden" name="scales[]" value="<%= s %>" />
          <% end %>
          <%= f.hidden_field :series, value: @discovery_form[:series] %>
          <%= f.hidden_field :max_pages, value: @discovery_form[:max_pages] %>
          <%= f.hidden_field :max_items, value: @discovery_form[:max_items] %>
          <button type="submit" name="discovery_mode" value="full" class="btn btn-primary">
            <i class="fa-solid fa-arrows-rotate me-1"></i> Ejecutar descubrimiento completo
          </button>
          <button type="submit" name="discovery_mode" value="test" class="btn btn-outline-success">
            <i class="fa-solid fa-vial-circle-check me-1"></i> Prueba rápida (pocos productos)
          </button>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# ── Progreso en vivo (solo si hay una corrida activa de verdad) ── %>
<% if @active_discovery_run.present? %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0"><i class="fa-solid fa-spinner fa-spin me-2"></i> Corrida en progreso</h5>
        <div class="d-flex gap-2">
          <%= button_to stop_discovery_admin_supplier_catalog_items_path, method: :post, class: "btn btn-outline-warning btn-sm" do %>
            <i class="fa-solid fa-stop me-1"></i> Solicitar detención
          <% end %>
          <%= button_to cancel_discovery_admin_supplier_catalog_items_path, method: :post, class: "btn btn-outline-danger btn-sm",
                data: { turbo_confirm: "¿Cancelar la corrida forzadamente? Se marcará como cancelada." } do %>
            <i class="fa-solid fa-xmark me-1"></i> Cancelar
          <% end %>
        </div>
      </div>
      <%= render "discovery_progress_frame", run: @active_discovery_run %>
    </div>
  </div>
<% end %>

<%# ── Corridas recientes ── %>
<div class="row g-4">
  <div class="col-12 col-xl-4 ms-auto">
    <%= render "recent_runs", recent_runs: @recent_runs %>
  </div>
</div>