<div class="admin-page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <p class="admin-page-eyebrow mb-1">Proveedor</p>
    <h2 class="mb-0 d-flex align-items-center gap-2"><i class="fa-solid fa-cloud-arrow-down"></i> Catálogo proveedor</h2>
  </div>
  <div class="d-flex gap-2">
    <% if @active_discovery_run.present? %>
      <%= button_to stop_discovery_admin_supplier_catalog_items_path, method: :post, class: "btn btn-outline-danger" do %>
        <i class="fa-solid fa-stop me-1"></i> Detener descubrimiento
      <% end %>
    <% end %>
  </div>
</div>

<%= render "discovery_progress_frame", run: @active_discovery_run %>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm"><div class="card-body py-3"><small class="text-muted d-block">Total</small><span class="fs-4 fw-bold"><%= @counts[:total] %></span></div></div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm"><div class="card-body py-3"><small class="text-muted d-block">Vinculados</small><span class="fs-4 fw-bold text-success"><%= @counts[:linked] %></span></div></div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm"><div class="card-body py-3"><small class="text-muted d-block">Sin vincular</small><span class="fs-4 fw-bold text-warning"><%= @counts[:unlinked] %></span></div></div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm"><div class="card-body py-3"><small class="text-muted d-block">Future release</small><span class="fs-4 fw-bold text-primary"><%= @counts[:future_release] %></span></div></div>
  </div>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <div class="row g-3 align-items-end">
      <div class="col-12">
        <h5 class="mb-1">Ejecución HLJ</h5>
        <p class="text-muted mb-0">Primero consulta una vista previa sin guardar; después ejecuta el scrapeo real para persistir lo que sí quieras importar.</p>
      </div>
    </div>

    <%= form_with url: run_discovery_admin_supplier_catalog_items_path, method: :post, local: true, class: "row g-3 align-items-end mt-1" do |f| %>
      <div class="col-12 col-md-3">
        <%= f.label :preset, "Preset", class: "form-label" %>
        <%= f.select :preset, options_for_select(@discovery_preset_options, @discovery_form[:preset]), {}, class: "form-select" %>
      </div>
      <div class="col-12 col-md-3">
        <%= f.label :word, "Word", class: "form-label" %>
        <%= f.text_field :word, value: @discovery_form[:word], class: "form-control", placeholder: "Ej. tomica" %>
      </div>
      <div class="col-12 col-md-3">
        <%= f.label :makers, "Makers", class: "form-label" %>
        <%= f.text_field :makers, value: @discovery_form[:makers], class: "form-control", placeholder: "Takara Tomy, Tomy, Tomytec" %>
      </div>
      <div class="col-12 col-md-3">
        <%= f.label :genre_code, "Género HLJ", class: "form-label" %>
        <%= f.text_field :genre_code, value: @discovery_form[:genre_code], class: "form-control", placeholder: "Cars & Bikes" %>
      </div>
      <div class="col-6 col-md-2">
        <%= f.label :max_pages, "Máx. páginas", class: "form-label" %>
        <%= f.number_field :max_pages, value: @discovery_form[:max_pages], min: 1, class: "form-control" %>
      </div>
      <div class="col-6 col-md-2">
        <%= f.label :max_items, "Máx. productos", class: "form-label" %>
        <%= f.number_field :max_items, value: @discovery_form[:max_items], min: 1, class: "form-control" %>
      </div>
      <div class="col-12 col-md-8 d-flex flex-wrap gap-2">
        <button type="submit" formaction="<%= preview_discovery_admin_supplier_catalog_items_path %>" formmethod="post" class="btn btn-outline-secondary">
          <i class="fa-solid fa-magnifying-glass me-1"></i> Vista previa HLJ
        </button>
        <button type="submit" name="discovery_mode" value="full" class="btn btn-primary">
          <i class="fa-solid fa-arrows-rotate me-1"></i> Ejecutar descubrimiento HLJ
        </button>
        <button type="submit" name="discovery_mode" value="test" class="btn btn-outline-success">
          <i class="fa-solid fa-vial-circle-check me-1"></i> Prueba rápida HLJ
        </button>
      </div>
    <% end %>
  </div>
</div>

<% if @discovery_preview.present? %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white">
      <h5 class="mb-0">Vista previa HLJ</h5>
    </div>
    <div class="card-body">
      <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
          <div class="border rounded p-3 h-100">
            <small class="text-muted d-block">Productos encontrados</small>
            <div class="fs-4 fw-bold"><%= @discovery_preview.total_found %></div>
            <div class="small text-muted">en <%= @discovery_preview.scanned_pages %> página(s) consultadas</div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="border rounded p-3 h-100">
            <small class="text-muted d-block">Muestra visible</small>
            <div class="fs-4 fw-bold"><%= @discovery_preview.sample_items.size %></div>
            <div class="small text-muted">primeros <%= @discovery_preview.sample_limit %> resultados, sin guardar en BD</div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="border rounded p-3 h-100">
            <small class="text-muted d-block">Páginas disponibles</small>
            <div class="fs-4 fw-bold"><%= @discovery_preview.available_pages %></div>
            <div class="small text-muted">según la navegación detectada en HLJ</div>
          </div>
        </div>
      </div>

      <% if @discovery_preview.sample_items.any? %>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Artículo</th>
                <th>SKU externo</th>
                <th>Precio listado</th>
                <th>Imagen</th>
              </tr>
            </thead>
            <tbody>
              <% @discovery_preview.sample_items.each do |item| %>
                <tr>
                  <td>
                    <div class="fw-semibold"><%= item[:name] %></div>
                    <div class="small text-muted" style="word-break: break-all;"><%= item[:source_url] %></div>
                  </td>
                  <td><%= item[:external_sku] %></td>
                  <td><%= item[:listing_price_text].presence || "—" %></td>
                  <td>
                    <% if item[:listing_image_url].present? %>
                      <a href="<%= item[:listing_image_url] %>" target="_blank" rel="noopener">Ver imagen</a>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-muted mb-0">No se encontraron productos con esos filtros.</p>
      <% end %>
    </div>
  </div>
<% end %>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: admin_supplier_catalog_items_path, method: :get, local: true, class: "row g-3 align-items-end" do |f| %>
      <div class="col-12 col-md-5">
        <%= f.label :q, "Buscar", class: "form-label" %>
        <%= f.text_field :q, value: @q, class: "form-control", placeholder: "Nombre, SKU externo o código de barras" %>
      </div>
      <div class="col-6 col-md-3">
        <%= f.label :status, "Status HLJ", class: "form-label" %>
        <%= f.select :status, options_for_select([["Todos", ""]] + @status_options.map { |status| [status.to_s.humanize, status] }, @status), {}, class: "form-select" %>
      </div>
      <div class="col-6 col-md-2">
        <%= f.label :linked, "Vinculado", class: "form-label" %>
        <%= f.select :linked, options_for_select([["Todos", ""], ["Sí", "yes"], ["No", "no"]], @link_filter), {}, class: "form-select" %>
      </div>
      <div class="col-12 col-md-2 d-grid">
        <%= f.submit "Filtrar", class: "btn btn-outline-primary" %>
      </div>
    <% end %>
  </div>
</div>

<div class="row g-4">
  <div class="col-12 col-xl-9">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white"><h5 class="mb-0">Artículos detectados</h5></div>
      <div class="card-body p-0">
        <% if @supplier_catalog_items.any? %>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Artículo</th>
                  <th>Status</th>
                  <th>Precio</th>
                  <th>Release</th>
                  <th>Producto</th>
                  <th class="text-end"></th>
                </tr>
              </thead>
              <tbody>
                <% @supplier_catalog_items.each do |item| %>
                  <tr>
                    <td>
                      <div class="fw-semibold"><%= item.canonical_name %></div>
                      <div class="small text-muted"><%= item.external_sku %> · <%= item.barcode.presence || "Sin barcode" %></div>
                    </td>
                    <td>
                      <span class="badge <%= item.future_release? ? 'bg-primary' : item.canonical_status == 'in_stock' ? 'bg-success' : 'bg-secondary' %>"><%= item.canonical_status.presence || 'unknown' %></span>
                    </td>
                    <td><%= item.canonical_price ? number_to_currency(item.canonical_price) : "—" %></td>
                    <td><%= item.canonical_release_date&.strftime("%Y-%m-%d") || "—" %></td>
                    <td>
                      <% if item.product.present? %>
                        <%= link_to item.product.product_name, admin_product_path(item.product), class: "text-decoration-none" %>
                      <% else %>
                        <span class="text-muted">Sin vincular</span>
                      <% end %>
                    </td>
                    <td class="text-end">
                      <%= link_to admin_supplier_catalog_item_path(item), class: "btn btn-outline-primary btn-sm" do %>
                        <i class="fa-solid fa-eye"></i> Ver
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <div class="p-3"><%= paginate @supplier_catalog_items %></div>
        <% else %>
          <div class="text-center text-muted py-5">
            <i class="fa-solid fa-inbox fa-3x mb-3 d-block"></i>
            <p class="mb-0">No hay artículos en catálogo proveedor.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-12 col-xl-3">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white"><h5 class="mb-0">Corridas recientes</h5></div>
      <div class="card-body">
        <% if @recent_runs.any? %>
          <div class="vstack gap-3">
            <% @recent_runs.each do |run| %>
              <div class="border rounded p-2">
                <div class="fw-semibold small"><%= run.source %> · <%= run.mode %></div>
                <div class="small text-muted"><%= run.status %> · <%= l(run.created_at, format: :short) %></div>
                <div class="small text-muted">Procesados: <%= run.processed_count %> · Errores: <%= run.error_count %></div>
                <% if run.metadata.present? %>
                  <% filters = [] %>
                  <% filters << "preset #{run.metadata['preset']}" if run.metadata['preset'].present? %>
                  <% filters << "word=#{run.metadata['word']}" if run.metadata['word'].present? %>
                  <% filters << "makers=#{Array(run.metadata['makers']).join(' / ')}" if Array(run.metadata['makers']).any? %>
                  <% filters << "género=#{run.metadata['genre_code']}" if run.metadata['genre_code'].present? %>
                  <% filters << "páginas=#{run.metadata['max_pages']}" if run.metadata['max_pages'].present? %>
                  <% filters << "productos=#{run.metadata['max_items']}" if run.metadata['max_items'].present? %>
                  <% if filters.any? %>
                    <div class="small text-muted"><%= filters.join(' · ') %></div>
                  <% end %>
                <% end %>
                <% if run.stop_requested? %>
                  <div class="small text-warning">Detención solicitada</div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted mb-0">Aún no hay corridas registradas.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>