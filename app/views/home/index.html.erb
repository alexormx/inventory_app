<% content_for :title, t('home.index.meta.title') %>
<% content_for :meta_description, t('home.index.meta.description') %>
<% content_for :canonical_url, root_url %>

<style>
  .hero-section { isolation: isolate; }
  .hero-picture { position: absolute; inset: 0; z-index: 0; display: block; }
  .hero-image {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    display: block;
  }
  .hero-overlay {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    /* Scrim oscuro centrado para garantizar contraste del título sobre
       cualquier zona clara de la foto, con el tinte rojo de marca encima. */
    background:
      radial-gradient(ellipse at center,
        rgba(0,0,0,0.62) 0%,
        rgba(0,0,0,0.32) 55%,
        rgba(0,0,0,0.18) 100%),
      linear-gradient(135deg,
        rgba(220,53,69,0.42) 0%,
        rgba(185,28,28,0.42) 50%,
        rgba(127,29,29,0.48) 100%);
  }
  .hero-section > .container { position: relative; z-index: 2; }
  /* La palabra resaltada del título (text-danger) en rojo de marca se
     pierde sobre la foto oscura; la aclaramos solo dentro del hero. */
  .hero-section .text-danger { color: #ff8a8a !important; }
  /* Imagen de producto destacado: conserva el encuadre original
     (contain en caja de 200px) ahora que el helper la envuelve en
     <picture> con variantes WebP/AVIF responsive. */
  .featured-products .card > a > picture { display: block; }
  .home-featured-img { width: 100%; height: 200px; object-fit: contain; background: #f8f9fa; }
</style>

<!-- ✨ HERO SECTION -->
<section class="hero-section position-relative d-flex align-items-center text-white" style="min-height: 60vh; overflow: hidden;">
  <%
    hero_base = 'collection_shelf'
    hero_widths = [480, 768, 960, 1440]
    hero_responsive_avif = hero_widths.all? { |w| asset_exists?("#{hero_base}-#{w}w.avif") }
    hero_responsive_webp = hero_widths.all? { |w| asset_exists?("#{hero_base}-#{w}w.webp") }
    hero_responsive_jpg  = hero_widths.all? { |w| asset_exists?("#{hero_base}-#{w}w.jpg") }
    hero_sizes = '100vw'
    hero_srcset = ->(ext) { hero_widths.map { |w| "#{asset_path("#{hero_base}-#{w}w.#{ext}")} #{w}w" }.join(', ') }
  %>
  <picture class="hero-picture">
    <%# Prefer responsive AVIF (smallest) when all widths exist on disk;
        skip AVIF entirely if only the full-size 2.7MB version is present
        so we don't trade responsive sizing for marginal format gains. %>
    <% if hero_responsive_avif %>
      <source type="image/avif" srcset="<%= hero_srcset.call('avif') %>" sizes="<%= hero_sizes %>">
    <% end %>
    <% if hero_responsive_webp %>
      <source type="image/webp" srcset="<%= hero_srcset.call('webp') %>" sizes="<%= hero_sizes %>">
    <% elsif asset_exists?("#{hero_base}.webp") %>
      <source type="image/webp" srcset="<%= asset_path("#{hero_base}.webp") %>">
    <% end %>
    <% if hero_responsive_jpg %>
      <%= image_tag "#{hero_base}-960w.jpg",
                    alt: '',
                    class: 'hero-image',
                    srcset: hero_srcset.call('jpg'),
                    sizes: hero_sizes,
                    fetchpriority: 'high',
                    loading: 'eager',
                    decoding: 'async',
                    width: 1440,
                    height: 936 %>
    <% else %>
      <%= image_tag "#{hero_base}.jpg",
                    alt: '',
                    class: 'hero-image',
                    fetchpriority: 'high',
                    loading: 'eager',
                    decoding: 'async',
                    width: 1920,
                    height: 1080 %>
    <% end %>
  </picture>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="container position-relative text-center" style="z-index: 2;">
    <h1 class="display-3 fw-bold mb-3" style="text-shadow: 0 2px 18px rgba(0,0,0,0.8), 0 1px 3px rgba(0,0,0,0.6);"><%= t('home.index.heading_html').html_safe %></h1>
    <p class="fs-5 fw-semibold mb-4" style="max-width: 800px; margin: 0 auto; text-shadow: 0 1px 8px rgba(0,0,0,0.6);"><%= t('home.index.subheading_html').html_safe %></p>
    <p class="lead mb-5 fs-5" style="max-width: 700px; margin: 0 auto; text-shadow: 0 1px 8px rgba(0,0,0,0.6);"><%= t('home.index.lead') %></p>
    <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
      <% if user_signed_in? %>
        <%= link_to catalog_path, class: "btn btn-light btn-lg px-5 py-3 shadow-sm" do %>
          <i class="fas fa-store me-2"></i><%= t('home.index.explore_cta') %>
        <% end %>
      <% else %>
        <%= link_to new_user_registration_path, class: "btn btn-light btn-lg px-5 py-3 shadow-sm" do %>
          <i class="fas fa-user-plus me-2"></i><%= t('home.index.register_cta') %>
        <% end %>
        <%= link_to new_user_session_path, class: "btn btn-outline-light btn-lg px-5 py-3" do %>
          <i class="fas fa-sign-in-alt me-2"></i><%= t('home.index.login_cta') %>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<!-- 📊 ESTADÍSTICAS -->
<section class="stats-section py-4 bg-dark text-white">
  <div class="container">
    <div class="row text-center justify-content-center">
      <div class="col-4 col-md-3">
        <div class="stat-item">
          <i class="fas fa-box-open mb-2" style="font-size: 1.5rem; color: #c92a2a;"></i>
          <div class="fs-2 fw-bold" style="color: #c92a2a;"><%= number_with_delimiter(@stats[:products]) %>+</div>
          <div class="small text-uppercase" style="letter-spacing: 1px; color: var(--public-muted);">Productos</div>
        </div>
      </div>
      <div class="col-4 col-md-3">
        <div class="stat-item">
          <i class="fas fa-users mb-2" style="font-size: 1.5rem; color: #c92a2a;"></i>
          <div class="fs-2 fw-bold" style="color: #c92a2a;"><%= number_with_delimiter(@stats[:customers]) %>+</div>
          <div class="small text-uppercase" style="letter-spacing: 1px; color: var(--public-muted);">Clientes Felices</div>
        </div>
      </div>
      <div class="col-4 col-md-3">
        <div class="stat-item">
          <i class="fas fa-award mb-2" style="font-size: 1.5rem; color: #c92a2a;"></i>
          <div class="fs-2 fw-bold" style="color: #c92a2a;"><%= @stats[:years] %>+</div>
          <div class="small text-uppercase" style="letter-spacing: 1px; color: var(--public-muted);">Años de Experiencia</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 🏷️ CATEGORÍAS DESTACADAS -->
<% if @featured_categories.present? %>
<section class="categories-section py-5 bg-light">
  <div class="container">
    <div class="text-center mb-4">
      <h2 class="display-6 fw-bold mb-2">Explora por Categoría</h2>
      <p class="text-muted">Encuentra exactamente lo que buscas</p>
    </div>
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3">
      <%
        # Ícono por palabra clave (con respaldo) y paleta cíclica de colores.
        category_icons = {
          'auto' => 'fa-car', 'escala' => 'fa-car', 'diecast' => 'fa-car',
          'tomica' => 'fa-car-side', 'hot wheels' => 'fa-car-side',
          'figura' => 'fa-chess-knight', 'coleccion' => 'fa-gem',
          'juguete' => 'fa-puzzle-piece', 'carta' => 'fa-clone',
          'modelo' => 'fa-cubes', 'kit' => 'fa-screwdriver-wrench'
        }
        palette = %w[danger primary warning success info secondary]
      %>
      <% @featured_categories.each_with_index do |cat, i| %>
        <% key = cat.to_s.downcase %>
        <% icon = (category_icons.find { |k, _| key.include?(k) }&.last) || 'fa-cubes' %>
        <div class="col">
          <%= link_to category_landing_path(category_slug: cat.parameterize), class: "text-decoration-none" do %>
            <div class="card border-0 shadow-sm h-100 text-center hover-lift">
              <div class="card-body py-4">
                <div class="mb-2">
                  <i class="fas <%= icon %> fa-2x text-<%= palette[i % palette.size] %>"></i>
                </div>
                <h3 class="card-title mb-0 fw-semibold text-dark small"><%= cat %></h3>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- 🌟 PRODUCTOS DESTACADOS -->
<% featured_products = @products.select { |p| p.current_on_hand > 0 }.first(8) %>
<% if featured_products.present? %>
<section class="featured-products py-5">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="display-5 fw-bold mb-3">Productos Destacados</h2>
      <p class="lead text-muted">Descubre las últimas novedades de nuestra colección</p>
    </div>
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4 mb-4">
      <% featured_products.each do |product| %>
        <div class="col">
          <div class="card h-100 border-0 shadow-sm hover-lift">
            <%= link_to product_path(product), class: "text-decoration-none" do %>
              <% if product.product_images&.attached? %>
                <%= responsive_attachment_image product.primary_product_image,
                      alt: product.product_name,
                      widths: [200, 240, 300, 400],
                      sizes: "(min-width: 992px) 17vw, (min-width: 768px) 24vw, 33vw",
                      css_class: "card-img-top p-3 home-featured-img",
                      loading: "lazy" %>
              <% else %>
                <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center text-white" style="height: 200px;">
                  <i class="fas fa-image fa-3x opacity-50"></i>
                </div>
              <% end %>
              <div class="card-body text-center">
                <h3 class="card-title text-dark mb-0 fw-semibold" style="font-size: 0.9rem;"><%= product.product_name %></h3>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="text-center">
      <%= link_to catalog_path, class: "btn btn-danger btn-lg px-5" do %>
        Ver Catálogo Completo <i class="fas fa-arrow-right ms-2"></i>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- ✅ TRUST BADGES -->
<section class="trust-section py-5 bg-light">
  <div class="container">
    <div class="row row-cols-2 row-cols-md-4 g-4 text-center">
      <div class="col">
        <div class="trust-badge">
          <i class="fas fa-truck fa-2x text-danger mb-3"></i>
          <h3 class="fw-bold mb-1 fs-6">Envío Seguro</h3>
          <p class="small text-muted mb-0">Empaque profesional</p>
        </div>
      </div>
      <div class="col">
        <div class="trust-badge">
          <i class="fas fa-shield-alt fa-2x text-danger mb-3"></i>
          <h3 class="fw-bold mb-1 fs-6">Pago Protegido</h3>
          <p class="small text-muted mb-0">Transacciones seguras</p>
        </div>
      </div>
      <div class="col">
        <div class="trust-badge">
          <i class="fas fa-certificate fa-2x text-danger mb-3"></i>
          <h3 class="fw-bold mb-1 fs-6">100% Original</h3>
          <p class="small text-muted mb-0">Garantía de autenticidad</p>
        </div>
      </div>
      <div class="col">
        <div class="trust-badge">
          <i class="fas fa-headset fa-2x text-danger mb-3"></i>
          <h3 class="fw-bold mb-1 fs-6">Soporte</h3>
          <p class="small text-muted mb-0">Atención personalizada</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 💎 VALUE PROPOSITIONS -->
<div class="container py-5">
  <div class="text-center mb-5">
    <h2 class="display-5 fw-bold mb-3">¿Por qué Pasatiempos?</h2>
    <p class="lead text-muted">Tu aliado en el mundo del coleccionismo</p>
  </div>

  <div class="row row-cols-1 row-cols-md-2 g-4 mb-5">
    <div class="col">
      <div class="card border-0 shadow-sm h-100 hover-lift">
        <div class="card-body text-center p-4">
          <div class="mb-3">
            <i class="fas fa-box-open text-danger fa-3x"></i>
          </div>
          <h3 class="card-title fw-bold mb-3 fs-5"><%= t('home.index.cards.collection.title') %></h3>
          <p class="card-text text-muted"><%= t('home.index.cards.collection.text') %></p>
        </div>
      </div>
    </div>
    <div class="col">
      <div class="card border-0 shadow-sm h-100 hover-lift">
        <div class="card-body text-center p-4">
          <div class="mb-3">
            <i class="fas fa-users text-danger fa-3x"></i>
          </div>
          <h3 class="card-title fw-bold mb-3 fs-5"><%= t('home.index.cards.community.title') %></h3>
          <p class="card-text text-muted"><%= t('home.index.cards.community.text') %></p>
        </div>
      </div>
    </div>
    <div class="col">
      <div class="card border-0 shadow-sm h-100 hover-lift">
        <div class="card-body text-center p-4">
          <div class="mb-3">
            <i class="fas fa-heart text-danger fa-3x"></i>
          </div>
          <h3 class="card-title fw-bold mb-3 fs-5"><%= t('home.index.cards.legacy.title') %></h3>
          <p class="card-text text-muted"><%= t('home.index.cards.legacy.text') %></p>
        </div>
      </div>
    </div>
    <div class="col">
      <div class="card border-0 shadow-sm h-100 hover-lift">
        <div class="card-body text-center p-4">
          <div class="mb-3">
            <i class="fas fa-shield-alt text-danger fa-3x"></i>
          </div>
          <h3 class="card-title fw-bold mb-3 fs-5"><%= t('home.index.cards.practices.title') %></h3>
          <p class="card-text text-muted"><%= t('home.index.cards.practices.text') %></p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 📧 NEWSLETTER -->
<section class="newsletter-section py-5 text-white" style="background: linear-gradient(135deg, #a01828 0%, #7f1d1d 100%);">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8 text-center">
        <h2 class="display-6 fw-bold mb-3">¡Mantente Actualizado!</h2>
        <p class="lead mb-4">Recibe las últimas novedades, ofertas exclusivas y lanzamientos directamente en tu correo.</p>
        <%= form_with model: NewsletterSubscriber.new, url: newsletter_subscribers_path, class: "row g-3 justify-content-center" do |f| %>
          <div class="col-12 col-md-7">
            <%= f.email_field :email, class: "form-control form-control-lg", placeholder: "Tu correo electrónico", required: true %>
          </div>
          <div class="col-12 col-md-auto">
            <%= f.submit "Suscribirse", class: "btn btn-light btn-lg px-5 w-100" %>
          </div>
        <% end %>
        <p class="small mt-3 opacity-75">
          <i class="fas fa-lock me-1"></i>Tu privacidad es importante. No compartimos tu información.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- 🚀 CALL TO ACTION -->
<% unless user_signed_in? %>
<div class="container my-5 py-5 text-center">
  <h2 class="fw-bold text-danger mb-3"><%= t('home.index.join_title') %></h2>
  <p class="lead mb-4"><%= t('home.index.join_lead') %></p>
  <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
    <%= link_to new_user_session_path, class: "btn btn-outline-danger btn-lg px-5 py-3" do %>
      <i class="fas fa-sign-in-alt me-2"></i><%= t('home.index.login_cta') %>
    <% end %>
    <%= link_to new_user_registration_path, class: "btn btn-danger btn-lg px-5 py-3" do %>
      <i class="fas fa-user-plus me-2"></i><%= t('home.index.register_cta') %>
    <% end %>
  </div>
</div>
<% end %>
