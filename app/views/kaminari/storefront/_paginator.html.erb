<%# Theme "storefront": markup Bootstrap 5 (.pagination > .page-item > .page-link)
    para que el CSS de #catalog .pagination aplique (pills + rojo de marca).
    El <nav> contenedor lo aporta _product_grid; aquí solo va el <ul>. -%>
<%= paginator.render do -%>
  <ul class="pagination justify-content-center mb-0">
    <%= first_page_tag unless current_page.first? %>
    <%= prev_page_tag unless current_page.first? %>
    <% each_page do |page| -%>
      <% if page.display_tag? -%>
        <%= page_tag page %>
      <% elsif !page.was_truncated? -%>
        <%= gap_tag %>
      <% end -%>
    <% end -%>
    <% unless current_page.out_of_range? %>
      <%= next_page_tag unless current_page.last? %>
      <%= last_page_tag unless current_page.last? %>
    <% end %>
  </ul>
<% end -%>
