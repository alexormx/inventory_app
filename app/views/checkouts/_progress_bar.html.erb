<%# Partial para barra de progreso del checkout %>
<%# Uso: render 'checkouts/progress_bar', current_step: 1 %>
<% current_step ||= 1 %>
<% steps = [
  { number: 1, name: 'Productos', icon: '🛒', path: checkout_step1_path },
  { number: 2, name: 'Envío', icon: '🚚', path: checkout_step2_path },
  { number: 3, name: 'Pago', icon: '💳', path: checkout_step3_path }
] %>

<nav class="checkout-progress-wrapper mb-4" aria-label="Progreso del checkout">
  <ol class="d-flex justify-content-between align-items-center position-relative list-unstyled m-0">
    <!-- Línea de conexión de fondo -->
    <div class="progress-line position-absolute" aria-hidden="true"></div>
    <div class="progress-line-active position-absolute" aria-hidden="true" style="width: <%= (current_step - 1) * 40 %>%;"></div>

    <% steps.each do |step| %>
      <% is_completed = step[:number] < current_step %>
      <% is_current = step[:number] == current_step %>

      <li class="progress-step text-center position-relative"<%= ' aria-current="step"'.html_safe if is_current %>>
        <% if is_completed %>
          <%= link_to step[:path], class: 'text-decoration-none', 'aria-label': "Paso #{step[:number]}: #{step[:name]} (completado)" do %>
            <div class="progress-circle rounded-circle d-inline-flex align-items-center justify-content-center bg-success text-white" aria-hidden="true">
              ✓
            </div>
            <div class="mt-2 small text-success fw-medium"><%= step[:name] %></div>
          <% end %>
        <% elsif is_current %>
          <div class="progress-circle rounded-circle d-inline-flex align-items-center justify-content-center bg-primary text-white shadow" aria-hidden="true">
            <%= step[:icon] %>
          </div>
          <div class="mt-2 small text-primary fw-bold"><%= step[:name] %></div>
        <% else %>
          <div class="progress-circle rounded-circle d-inline-flex align-items-center justify-content-center bg-light text-muted border" aria-hidden="true">
            <%= step[:number] %>
          </div>
          <div class="mt-2 small text-muted"><%= step[:name] %></div>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
