<%= turbo_frame_tag "products_grid", autoscroll: true, data: { autoscroll_block: "start", autoscroll_behavior: "smooth" } do %>
  <%# Resumen dinámico — vive dentro del frame, se actualiza en cada cambio de filtro %>
  <% total_products = @products.total_count %>
  <% has_filters = filter_state.has_filters || @q.present? %>
  <div class="catalog-results-summary d-flex flex-wrap align-items-baseline gap-2 mb-3" aria-live="polite">
    <span class="catalog-results-count">
      <strong class="catalog-results-count-number"><%= number_with_delimiter(total_products) %></strong>
      <span class="catalog-results-count-label"><%= total_products == 1 ? 'producto' : 'productos' %></span>
    </span>
    <% if has_filters %>
      <span class="catalog-results-context text-muted small">
        <i class="fas fa-filter me-1" aria-hidden="true"></i>
        <% if @q.present? %>
          coinciden con "<strong class="text-dark"><%= @q %></strong>"
        <% else %>
          coinciden con tus filtros
        <% end %>
      </span>
    <% else %>
      <span class="catalog-results-context text-muted small">en el catálogo</span>
    <% end %>
  </div>

  <%# Chips de filtros activos (sólo cuando hay filtros aplicados) %>
  <%= render 'filter_chips' %>

  <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xxl-5 g-4" id="product-grid-content" role="list">
    <% @products.each do |product| %>
      <% on_hand_cached = @on_hand_counts[product.id] || 0 %>
      <% in_transit_eta_cached = (defined?(@in_transit_etas) && @in_transit_etas[product.id]) || nil %>
      <% has_image = product.product_images.attached? %>
      <div class="col product-card-wrapper" data-product-id="<%= product.id %>" role="listitem">
        <article class="card h-100 border-0 shadow-sm d-flex flex-column catalog-item position-relative hover-lift">
          <% if product.active? %>
            <%= link_to product_path(product), class: "catalog-card-media d-block #{'catalog-card-media--empty' unless has_image}", aria: { label: "Ver detalles de #{product.product_name}" }, data: { turbo_frame: "_top" } do %>
              <% if has_image %>
                <%= responsive_attachment_image product.primary_product_image,
                  alt: product.product_name,
                  widths: [160,240,320,420],
                  css_class: "product-image mx-auto d-block",
                  square: true %>
              <% else %>
                <%= image_tag "placeholder.png", class: "product-image mx-auto d-block", alt: "Imagen no disponible para #{product.product_name}" %>
              <% end %>
            <% end %>
          <% else %>
            <div class="catalog-card-media d-block opacity-50 <%= 'catalog-card-media--empty' unless has_image %>" title="Producto inactivo">
              <% if has_image %>
                <%= responsive_attachment_image product.primary_product_image,
                  alt: product.product_name,
                  widths: [160,240,320,420],
                  css_class: "product-image mx-auto d-block",
                  square: true %>
              <% else %>
                <%= image_tag "placeholder.png", class: "product-image mx-auto d-block", alt: "Imagen no disponible" %>
              <% end %>
            </div>
          <% end %>
          <div class="card-body text-center d-flex flex-column w-100">
            <div class="catalog-badges catalog-badges--inline d-flex justify-content-center align-items-center" role="status" aria-live="polite">
              <% if product.active? %>
                <span><%= stock_badge(product, on_hand_override: on_hand_cached, in_transit_eta_override: in_transit_eta_cached) %></span>
              <% else %>
                <span class="badge bg-secondary">No disp.</span>
              <% end %>
              <% if product.created_at > 14.days.ago %>
                <span class="badge badge-new" title="Agregado recientemente">
                  <i class="fas fa-sparkles me-1" aria-hidden="true"></i>Nuevo
                </span>
              <% end %>
            </div>
            <h2 class="card-title catalog-card-title h6" title="<%= product.product_name %>">
              <% if product.active? %>
                <%= link_to product.product_name, product_path(product), class: "text-decoration-none text-dark", data: { turbo_frame: "_top" } %>
              <% else %>
                <span class="text-muted" aria-disabled="true"><%= product.product_name %></span>
              <% end %>
            </h2>
            <p class="catalog-card-price text-danger" role="text">
              <span class="visually-hidden">Precio: </span><%= number_to_currency(product.selling_price) %>
              <% unless user_signed_in? %>
                <i class="fas fa-circle-info catalog-fx-icon ms-1"
                   title="Sujeto al tipo de cambio del día de la compra"
                   aria-label="Sujeto al tipo de cambio del día de la compra"></i>
              <% end %>
            </p>
            <p class="catalog-card-meta text-muted">
              <% if product.brand.present? %>
                <span class="catalog-brand"><%= product.brand %></span>
              <% end %>
              <% if product.whatsapp_code.present? %>
                <span class="catalog-wa-code" title="Código para pedir por WhatsApp">
                  <i class="fab fa-whatsapp" aria-hidden="true"></i>
                  <%= product.whatsapp_code %>
                </span>
              <% end %>
            </p>
            <%# El badge ya muestra "Llega ~fecha" cuando hay inventario en tránsito,
                así que solo mostramos el ETA cuando viene de preventa/sobre-pedido. %>
            <% if product.active? && on_hand_cached <= 0 && in_transit_eta_cached.blank? && (eta = stock_eta(product)) %>
              <p class="catalog-card-eta text-muted extra-small"><i class="fa fa-clock me-1" aria-hidden="true"></i><span class="visually-hidden">Disponible: </span><%= eta %></p>
            <% end %>
            <% if product.active? %>
              <% on_hand = @on_hand_counts[product.id] || 0 %>
              <% has_in_transit = in_transit_eta_cached.present? %>
              <% can_reserve = has_in_transit || product.oversell_allowed? %>
              <% is_reservation = on_hand <= 0 && can_reserve %>
              <% disabled = on_hand <= 0 && !can_reserve %>
              <% reservation_tooltip = if has_in_transit
                                          "Reserva · Llega #{spanish_short_date(in_transit_eta_cached)}"
                                        elsif product.preorder_available
                                          'Reserva · Preventa'
                                        elsif product.backorder_allowed
                                          'Reserva · Sobre pedido'
                                        end %>
              <% btn_label = if disabled then 'Sin stock'
                             elsif is_reservation then 'Reservar'
                             else 'Agregar'
                             end %>
              <% btn_icon  = is_reservation ? 'fa-bookmark' : 'fa-cart-plus' %>
              <% btn_title = if disabled then 'Sin stock disponible'
                             elsif is_reservation then reservation_tooltip
                             else 'Agregar al carrito'
                             end %>
              <div class="catalog-card-actions d-flex gap-1 mt-auto">
                <% if user_signed_in? %>
                  <%= button_to cart_items_path,
                                params: { product_id: product.id },
                                method: :post,
                                class: "btn btn-danger btn-sm flex-grow-1 #{'disabled' if disabled}",
                                disabled: disabled,
                                title: btn_title,
                                aria: { label: (disabled ? 'Sin stock' : "#{btn_label} #{product.product_name}") } do %>
                    <i class="fas <%= btn_icon %> me-1" aria-hidden="true"></i><%= btn_label %>
                  <% end %>
                <% else %>
                  <%= link_to new_user_session_path, class: "btn btn-outline-danger btn-sm flex-grow-1", title: "Inicia sesión para agregar al carrito" do %>
                    <i class="fas fa-sign-in-alt me-1" aria-hidden="true"></i>Inicia sesión
                  <% end %>
                <% end %>
                <% if whatsapp_list_available? %>
                  <%= button_to whatsapp_list_items_path, params: { product_id: product.id },
                                method: :post,
                                class: "btn btn-outline-success btn-sm",
                                title: "Agregar a lista de WhatsApp",
                                aria: { label: "Agregar #{product.product_name} a lista de WhatsApp" },
                                data: { turbo_frame: "_top" } do %>
                    <i class="fab fa-whatsapp" aria-hidden="true"></i>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <button class="btn btn-outline-secondary btn-sm mt-auto" disabled title="Producto no disponible" aria-label="Producto no disponible">
                <i class="fas fa-ban" aria-hidden="true"></i>
              </button>
            <% end %>
          </div>
        </article>
      </div>
    <% end %>
  </div>

  <% if @products.empty? %>
    <div class="empty-state text-center py-5">
      <div class="empty-state-icon mb-4">
        <i class="fas fa-box-open fa-4x text-muted"></i>
      </div>
      <h4 class="fw-semibold mb-2">No se encontraron productos</h4>
      <% if @q.present? %>
        <p class="text-muted mb-3">No encontramos productos que coincidan con "<strong><%= @q %></strong>".</p>
      <% else %>
        <p class="text-muted mb-3">No hay productos disponibles con los filtros seleccionados.</p>
      <% end %>

      <div class="empty-state-actions d-flex flex-wrap justify-content-center gap-2 mb-4">
        <%= link_to catalog_path, class: "btn btn-danger", data: { turbo_frame: "products_grid", turbo_action: "advance" } do %>
          <i class="fas fa-redo me-1"></i>Ver todos los productos
        <% end %>
      </div>

      <%# Sugerencias de categorías reales (top por número de productos) %>
      <% suggestion_categories = (defined?(@top_categories) && @top_categories.presence) || (@all_categories || []).first(4) %>
      <% if suggestion_categories.present? %>
        <div class="empty-state-suggestions mt-4 pt-4 border-top">
          <p class="text-muted small mb-3">¿Buscas algo específico? Explora nuestras categorías:</p>
          <div class="d-flex flex-wrap justify-content-center gap-2">
            <% suggestion_categories.each do |cat| %>
              <%= link_to catalog_path(categories: [cat]), class: "btn btn-outline-secondary btn-sm", data: { turbo_frame: "products_grid", turbo_action: "advance" } do %>
                <i class="fas fa-tag me-1"></i><%= cat %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Paginación: info centrada arriba + paginador centrado abajo %>
  <% if @products.total_pages > 1 %>
    <nav class="catalog-pagination mt-4" id="pagination-container" aria-label="Paginación de productos">
      <div class="catalog-pagination-info text-center text-muted small mb-2">
        <%= products_range_text(@products) %>
        <span class="catalog-pagination-sep mx-2" aria-hidden="true">·</span>
        <span>Página <strong class="text-dark"><%= @products.current_page %></strong> de <strong class="text-dark"><%= @products.total_pages %></strong></span>
      </div>
      <div class="d-flex justify-content-center" data-turbo-action="advance">
        <%= paginate @products %>
      </div>
    </nav>
  <% end %>
<% end %>
