<%= turbo_frame_tag "products_grid" do %>
  <%# Chips de filtros activos dentro del frame para actualizar en cada request %>

  <% total_products = @products.total_count %>

  <% if @q.present? %>
    <div class="text-muted small mb-2">Resultados para "<strong><%= @q %></strong>"</div>
  <% end %>

  <%# Chips de filtros usando partial reutilizable %>
  <%= render 'filter_chips' %>

  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 row-cols-xxl-6 g-2 g-md-3" id="product-grid-content" role="list">
    <% @products.each do |product| %>
      <% on_hand_cached = @on_hand_counts[product.id] || 0 %>
      <% in_transit_eta_cached = (defined?(@in_transit_etas) && @in_transit_etas[product.id]) || nil %>
      <div class="col product-card-wrapper" data-product-id="<%= product.id %>" role="listitem">
        <article class="card h-100 border-0 shadow-sm d-flex flex-column catalog-item position-relative hover-lift">
          <!-- Badges agrupados arriba para evitar traslapes -->
          <div class="catalog-badges position-absolute top-0 start-0 end-0 d-flex justify-content-between align-items-start p-1" role="status" aria-live="polite">
            <% if product.active? %>
              <span><%= stock_badge(product, on_hand_override: on_hand_cached, in_transit_eta_override: in_transit_eta_cached) %></span>
            <% else %>
              <span class="badge bg-secondary">No disp.</span>
            <% end %>
            <% if product.created_at > 14.days.ago %>
              <span class="badge bg-info" title="Agregado recientemente">
                <i class="fas fa-sparkles me-1" aria-hidden="true"></i>Nuevo
              </span>
            <% end %>
          </div>
          <% if product.active? %>
            <%= link_to product_path(product), class: "d-block p-2", aria: { label: "Ver detalles de #{product.product_name}" }, data: { turbo_frame: "_top" } do %>
              <% if product.product_images.attached? %>
                <%= responsive_attachment_image product.primary_product_image,
                  alt: product.product_name,
                  widths: [60,96,150,200],
                  css_class: "product-image mx-auto d-block",
                  square: true %>
              <% else %>
                <%= image_tag "placeholder.png", class: "product-image mx-auto d-block", alt: "Imagen no disponible para #{product.product_name}" %>
              <% end %>
            <% end %>
          <% else %>
            <div class="d-block p-2 opacity-50" title="Producto inactivo">
              <% if product.product_images.attached? %>
                <%= responsive_attachment_image product.primary_product_image,
                  alt: product.product_name,
                  widths: [60,96,150,200],
                  css_class: "product-image mx-auto d-block",
                  square: true %>
              <% else %>
                <%= image_tag "placeholder.png", class: "product-image mx-auto d-block", alt: "Imagen no disponible" %>
              <% end %>
            </div>
          <% end %>
          <div class="card-body text-center p-2 d-flex flex-column w-100">
            <h2 class="card-title h6 mb-1" title="<%= product.product_name %>">
              <% if product.active? %>
                <%= link_to product.product_name, product_path(product), class: "text-decoration-none text-dark", data: { turbo_frame: "_top" } %>
              <% else %>
                <span class="text-muted" aria-disabled="true"><%= product.product_name %></span>
              <% end %>
            </h2>
            <p class="catalog-card-meta text-muted mb-1">
              <span class="catalog-brand"><%= product.brand %></span>
              <% if product.whatsapp_code.present? %>
                <span class="catalog-wa-code" title="Código para pedir por WhatsApp">
                  <i class="fab fa-whatsapp text-success" aria-hidden="true"></i>
                  <%= product.whatsapp_code %>
                </span>
              <% end %>
            </p>
            <p class="card-text text-danger fw-bold small mb-1" role="text">
              <span class="visually-hidden">Precio: </span><%= number_to_currency(product.selling_price) %>
            </p>
            <% unless user_signed_in? %>
              <p class="catalog-fx-note text-muted mb-2" title="El precio puede ajustarse al tipo de cambio del día de la compra">
                <i class="fas fa-circle-info me-1" aria-hidden="true"></i>Sujeto a tipo de cambio
              </p>
            <% end %>
            <%# El badge ya muestra "Llega ~fecha" cuando hay inventario en tránsito,
                así que solo mostramos el ETA cuando viene de preventa/sobre-pedido. %>
            <% if product.active? && on_hand_cached <= 0 && in_transit_eta_cached.blank? && (eta = stock_eta(product)) %>
              <p class="text-muted extra-small mb-2"><i class="fa fa-clock me-1" aria-hidden="true"></i><span class="visually-hidden">Disponible: </span><%= eta %></p>
            <% end %>
            <% if product.active? %>
              <% on_hand = @on_hand_counts[product.id] || 0 %>
              <% disabled = (on_hand <= 0 && !product.oversell_allowed?) %>
              <div class="catalog-card-actions d-flex gap-1 mt-auto">
                <% if user_signed_in? %>
                  <%= button_to cart_items_path,
                                params: { product_id: product.id },
                                method: :post,
                                class: "btn btn-danger btn-sm flex-grow-1 #{'disabled' if disabled}",
                                disabled: disabled,
                                title: (disabled ? 'Sin stock disponible' : 'Agregar al carrito'),
                                aria: { label: (disabled ? 'Sin stock' : "Agregar #{product.product_name} al carrito") } do %>
                    <i class="fas fa-cart-plus" aria-hidden="true"></i>
                    <span class="visually-hidden"><%= disabled ? 'Sin stock' : 'Agregar al carrito' %></span>
                  <% end %>
                <% else %>
                  <%= link_to new_user_session_path, class: "btn btn-outline-danger btn-sm flex-grow-1", title: "Inicia sesión para agregar al carrito" do %>
                    <i class="fas fa-sign-in-alt" aria-hidden="true"></i>
                    <span class="visually-hidden">Iniciar sesión</span>
                  <% end %>
                <% end %>
                <% if whatsapp_list_available? %>
                  <%= button_to whatsapp_list_items_path, params: { product_id: product.id },
                                method: :post,
                                class: "btn btn-outline-success btn-sm",
                                title: "Agregar a lista de WhatsApp",
                                aria: { label: "Agregar #{product.product_name} a lista de WhatsApp" },
                                data: { turbo_frame: "_top" } do %>
                    <i class="fab fa-whatsapp" aria-hidden="true"></i>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <button class="btn btn-outline-secondary btn-sm mt-auto" disabled title="Producto no disponible" aria-label="Producto no disponible">
                <i class="fas fa-ban" aria-hidden="true"></i>
              </button>
            <% end %>
          </div>
        </article>
      </div>
    <% end %>
  </div>

  <% if @products.empty? %>
    <div class="empty-state text-center py-5">
      <div class="empty-state-icon mb-4">
        <i class="fas fa-box-open fa-4x text-muted"></i>
      </div>
      <h4 class="fw-semibold mb-2">No se encontraron productos</h4>
      <% if @q.present? %>
        <p class="text-muted mb-3">No encontramos productos que coincidan con "<strong><%= @q %></strong>".</p>
      <% else %>
        <p class="text-muted mb-3">No hay productos disponibles con los filtros seleccionados.</p>
      <% end %>

      <div class="empty-state-actions d-flex flex-wrap justify-content-center gap-2 mb-4">
        <%= link_to catalog_path, class: "btn btn-danger", data: { turbo_frame: "products_grid", turbo_action: "advance" } do %>
          <i class="fas fa-redo me-1"></i>Ver todos los productos
        <% end %>
      </div>

      <%# Sugerencias de categorías reales (top por número de productos) %>
      <% suggestion_categories = (defined?(@top_categories) && @top_categories.presence) || (@all_categories || []).first(4) %>
      <% if suggestion_categories.present? %>
        <div class="empty-state-suggestions mt-4 pt-4 border-top">
          <p class="text-muted small mb-3">¿Buscas algo específico? Explora nuestras categorías:</p>
          <div class="d-flex flex-wrap justify-content-center gap-2">
            <% suggestion_categories.each do |cat| %>
              <%= link_to catalog_path(categories: [cat]), class: "btn btn-outline-secondary btn-sm", data: { turbo_frame: "products_grid", turbo_action: "advance" } do %>
                <i class="fas fa-tag me-1"></i><%= cat %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Paginación mejorada con info %>
  <% if @products.total_pages > 1 %>
    <div class="mt-4" id="pagination-container">
      <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-3 mb-3">
        <div class="text-muted small">
          <%= products_range_text(@products) %>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="text-muted small">Página <%= @products.current_page %> de <%= @products.total_pages %></span>
        </div>
      </div>
      <div class="d-flex justify-content-center" data-turbo-action="advance">
        <%= paginate @products %>
      </div>
    </div>
  <% end %>
<% end %>
