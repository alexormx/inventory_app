<%# La lógica de filtros ahora está centralizada en FilterParamsHelper#filter_state %>
<% is_mobile = suffix.to_s == 'Mobile' %>
<%# Compute per-section expand state. Sections start collapsed on mobile
    always, and on desktop when they have many items AND no active filter
    in that section — keeps the sidebar from being a tall wall of
    checkboxes. User can expand manually any time. %>
<% should_expand = ->(active:, item_count:) { active || (!is_mobile && item_count <= 12) } %>
<% categories_open = should_expand.call(active: filter_state.selected_categories.any?, item_count: @all_categories.to_a.size) %>
<% brands_open     = should_expand.call(active: filter_state.selected_brands.any?,     item_count: @all_brands.to_a.size) %>
<% series_open     = should_expand.call(active: filter_state.selected_series.any?,     item_count: @all_series.to_a.size) %>
<%# Disable an option when it would return zero results under the current
    filters (count == 0) and isn't already selected — avoids dead-end clicks. %>
<% zero_disabled = ->(count, selected) { !count.nil? && count.to_i.zero? && !selected } %>

<%= form_with url: catalog_path, method: :get, data: {
  turbo_frame: "_top",
  controller: "catalog-filters",
  action: "change->catalog-filters#submit input->catalog-filters#debouncedSubmit"
}, class: "catalog-sidebar-filters", id: form_id do %>
  <input type="hidden" name="sort" value="<%= @sort %>">
  <% if @q.present? %><input type="hidden" name="q" value="<%= @q %>"><% end %>

  <%# Cabecera: título + conteo de filtros activos + limpiar todo %>
  <div class="filter-sidebar-head d-flex align-items-center justify-content-between mb-3">
    <span class="filter-sidebar-title">
      <i class="fas fa-sliders me-1" aria-hidden="true"></i>Filtros
      <% if active_filters_count > 0 %>
        <span class="badge bg-danger rounded-pill ms-1"><%= active_filters_count %></span>
      <% end %>
    </span>
    <% if active_filters_count > 0 %>
      <%= link_to 'Limpiar', catalog_path, class: 'filter-clear-link', data: { turbo_frame: '_top' } %>
    <% end %>
  </div>

  <% if @all_categories.present? %>
  <div class="filter-block mb-3" data-controller="filter-list">
    <h6 class="fw-semibold small text-uppercase text-muted mb-2">
      <a class="text-decoration-none text-muted d-flex align-items-center justify-content-between" data-bs-toggle="collapse" href="#filterCategories<%= suffix %>" role="button" aria-expanded="<%= categories_open %>" aria-controls="filterCategories<%= suffix %>">
        Categorías
        <span>
          <% if filter_state.selected_categories.any? %>
            <span class="badge bg-danger rounded-pill me-1"><%= filter_state.selected_categories.size %></span>
          <% end %>
          <i class="fas fa-chevron-down"></i>
        </span>
      </a>
    </h6>
    <div class="collapse <%= 'show' if categories_open %>" id="filterCategories<%= suffix %>">
      <% if @all_categories.size > 8 %>
        <input type="search" class="form-control form-control-sm filter-search mb-2" placeholder="Buscar categoría..."
               data-filter-list-target="search" data-action="input->filter-list#filter" aria-label="Buscar categoría">
      <% end %>
      <div class="filter-scroll" data-filter-list-target="list">
        <% @all_categories.each do |c| %>
          <% c_count = (defined?(@facet_counts) && @facet_counts[:categories]) ? @facet_counts[:categories][c] : nil %>
          <% c_selected = filter_state.selected_categories.include?(c) %>
          <div class="form-check" data-filter-list-target="item" data-label="<%= c.to_s.downcase %>">
            <%= check_box_tag "categories[]", c, c_selected, id: "cat#{suffix}-#{c.parameterize}", class: "form-check-input", disabled: zero_disabled.call(c_count, c_selected) %>
            <label class="form-check-label" for="cat<%= suffix %>-<%= c.parameterize %>">
              <%= c %>
              <% if c_count %><span class="text-muted small">(<%= c_count %>)</span><% end %>
            </label>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <% end %>

  <% if @all_brands.present? %>
  <div class="filter-block mb-3" data-controller="filter-list">
    <h6 class="fw-semibold small text-uppercase text-muted mb-2">
      <a class="text-decoration-none text-muted d-flex align-items-center justify-content-between" data-bs-toggle="collapse" href="#filterBrands<%= suffix %>" role="button" aria-expanded="<%= brands_open %>" aria-controls="filterBrands<%= suffix %>">
        Marcas
        <span>
          <% if filter_state.selected_brands.any? %>
            <span class="badge bg-danger rounded-pill me-1"><%= filter_state.selected_brands.size %></span>
          <% end %>
          <i class="fas fa-chevron-down"></i>
        </span>
      </a>
    </h6>
    <div class="collapse <%= 'show' if brands_open %>" id="filterBrands<%= suffix %>">
      <% if @all_brands.size > 8 %>
        <input type="search" class="form-control form-control-sm filter-search mb-2" placeholder="Buscar marca..."
               data-filter-list-target="search" data-action="input->filter-list#filter" aria-label="Buscar marca">
      <% end %>
      <div class="filter-scroll" data-filter-list-target="list">
        <% @all_brands.each do |b| %>
          <% b_count = (defined?(@facet_counts) && @facet_counts[:brands]) ? @facet_counts[:brands][b] : nil %>
          <% b_selected = filter_state.selected_brands.include?(b) %>
          <div class="form-check" data-filter-list-target="item" data-label="<%= b.to_s.downcase %>">
            <%= check_box_tag "brands[]", b, b_selected, id: "brand#{suffix}-#{b.parameterize}", class: "form-check-input", disabled: zero_disabled.call(b_count, b_selected) %>
            <label class="form-check-label" for="brand<%= suffix %>-<%= b.parameterize %>">
              <%= b %>
              <% if b_count %><span class="text-muted small">(<%= b_count %>)</span><% end %>
            </label>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <% end %>

  <% if @all_series.present? %>
  <div class="filter-block mb-3" data-controller="filter-list">
    <h6 class="fw-semibold small text-uppercase text-muted mb-2">
      <a class="text-decoration-none text-muted d-flex align-items-center justify-content-between" data-bs-toggle="collapse" href="#filterSeries<%= suffix %>" role="button" aria-expanded="<%= series_open %>" aria-controls="filterSeries<%= suffix %>">
        Series
        <span>
          <% if filter_state.selected_series.any? %>
            <span class="badge bg-danger rounded-pill me-1"><%= filter_state.selected_series.size %></span>
          <% end %>
          <i class="fas fa-chevron-down"></i>
        </span>
      </a>
    </h6>
    <div class="collapse <%= 'show' if series_open %>" id="filterSeries<%= suffix %>">
      <% if @all_series.size > 8 %>
        <input type="search" class="form-control form-control-sm filter-search mb-2" placeholder="Buscar serie..."
               data-filter-list-target="search" data-action="input->filter-list#filter" aria-label="Buscar serie">
      <% end %>
      <div class="filter-scroll" data-filter-list-target="list">
        <% @all_series.each do |series| %>
          <% s_count = (defined?(@facet_counts) && @facet_counts[:series]) ? @facet_counts[:series][series] : nil %>
          <% s_selected = filter_state.selected_series.include?(series) %>
          <div class="form-check" data-filter-list-target="item" data-label="<%= series.to_s.downcase %>">
            <%= check_box_tag "series[]", series, s_selected, id: "series#{suffix}-#{series.parameterize}", class: "form-check-input", disabled: zero_disabled.call(s_count, s_selected) %>
            <label class="form-check-label" for="series<%= suffix %>-<%= series.parameterize %>">
              <%= series %>
              <% if s_count %><span class="text-muted small">(<%= s_count %>)</span><% end %>
            </label>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <% end %>

  <%# Precio — slider + inputs editables %>
  <div class="filter-block mb-3">
    <h6 class="fw-semibold small text-uppercase text-muted mb-2">
      <a class="text-decoration-none text-muted d-flex align-items-center justify-content-between" data-bs-toggle="collapse" href="#filterPrice<%= suffix %>" role="button" aria-expanded="true" aria-controls="filterPrice<%= suffix %>">
        Precio
        <span>
          <% if filter_state.price_min || filter_state.price_max %>
            <span class="badge bg-danger rounded-pill me-1">1</span>
          <% end %>
          <i class="fas fa-chevron-down"></i>
        </span>
      </a>
    </h6>
    <div class="collapse show" id="filterPrice<%= suffix %>">
      <div data-controller="price-range"
           data-price-range-min-value="<%= @price_range_min %>"
           data-price-range-max-value="<%= @price_range_max %>"
           data-price-range-current-min-value="<%= params[:price_min] || @price_range_min %>"
           data-price-range-current-max-value="<%= params[:price_max] || @price_range_max %>">

        <div class="mb-2 px-2 pt-2">
          <div data-price-range-target="slider" class="price-slider"></div>
        </div>

        <div class="price-inputs d-flex align-items-center gap-2 px-2">
          <div class="input-group input-group-sm">
            <span class="input-group-text">$</span>
            <input type="number" inputmode="numeric" class="form-control" name="price_min"
                   value="<%= params[:price_min] %>" data-price-range-target="minInput" data-debounce="true"
                   min="<%= @price_range_min %>" max="<%= @price_range_max %>"
                   placeholder="<%= @price_range_min %>" aria-label="Precio mínimo">
          </div>
          <span class="text-muted small" aria-hidden="true">–</span>
          <div class="input-group input-group-sm">
            <span class="input-group-text">$</span>
            <input type="number" inputmode="numeric" class="form-control" name="price_max"
                   value="<%= params[:price_max] %>" data-price-range-target="maxInput" data-debounce="true"
                   min="<%= @price_range_min %>" max="<%= @price_range_max %>"
                   placeholder="<%= @price_range_max %>" aria-label="Precio máximo">
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Condición física de la pieza — nicho, va al final %>
  <div class="filter-block mb-3">
    <h6 class="fw-semibold small text-uppercase text-muted mb-2">
      <a class="text-decoration-none text-muted d-flex align-items-center justify-content-between" data-bs-toggle="collapse" href="#filterCondition<%= suffix %>" role="button" aria-expanded="<%= filter_state.selected_conditions.any? %>" aria-controls="filterCondition<%= suffix %>">
        Condición
        <% active_cond = filter_state.selected_conditions.count %>
        <span>
          <% if active_cond > 0 %>
            <span class="badge bg-danger rounded-pill me-1"><%= active_cond %></span>
          <% end %>
          <i class="fas fa-chevron-down"></i>
        </span>
      </a>
    </h6>
    <div class="collapse <%= 'show' if filter_state.selected_conditions.any? %>" id="filterCondition<%= suffix %>">
      <% Product::CONDITION_GROUPS.each_key do |group_key| %>
        <% group_count = (defined?(@facet_counts) && @facet_counts[:conditions]) ? @facet_counts[:conditions][group_key] : nil %>
        <% cond_selected = filter_state.selected_conditions.include?(group_key) %>
        <div class="form-check">
          <%= check_box_tag "conditions[]", group_key, cond_selected, id: "f-cond-#{group_key}#{suffix}", class: "form-check-input", disabled: zero_disabled.call(group_count, cond_selected) %>
          <label class="form-check-label" for="f-cond-<%= group_key %><%= suffix %>">
            <%= Product::CONDITION_GROUP_LABELS[group_key] %>
            <% if group_count %>
              <span class="text-muted small">(<%= group_count %>)</span>
            <% end %>
          </label>
        </div>
      <% end %>
    </div>
  </div>

  <% if is_mobile %>
    <div class="filter-actions d-grid gap-2 mt-2">
      <button type="button" class="btn btn-danger" data-bs-dismiss="offcanvas">
        Ver <%= number_with_delimiter(@products.total_count) %> <%= @products.total_count == 1 ? 'resultado' : 'resultados' %>
      </button>
      <a href="<%= catalog_path %>" class="btn btn-outline-secondary btn-sm" data-turbo-frame="_top">Limpiar todo</a>
    </div>
  <% end %>
<% end %>
