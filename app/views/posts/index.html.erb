<% content_for :title, "Blog | #{seo_site_name}" %>
<% content_for :meta_description, "Guías, consejos y novedades de coleccionismo de autos a escala, diecast y figuras. Tomica, Hot Wheels, Greenlight y más en #{seo_site_name}." %>
<% content_for :canonical_url, blog_url %>

<div class="container py-4">
  <header class="mb-4 text-center">
    <h1 class="fw-bold display-5 mb-2">Blog de Pasatiempos</h1>
    <p class="lead text-muted mb-0">Guías, novedades y consejos para coleccionistas de autos a escala y figuras.</p>
  </header>

  <% if @posts.any? %>
    <div class="row g-4">
      <% @posts.each do |post| %>
        <article class="col-12 col-md-6 col-lg-4">
          <div class="card h-100 border-0 shadow-sm hover-lift">
            <%= link_to post_path(post), class: 'text-decoration-none' do %>
              <% if post.cover_image.attached? %>
                <%= image_tag post.cover_image,
                              alt: post.title,
                              class: 'card-img-top',
                              loading: 'lazy',
                              style: 'height: 200px; object-fit: cover;' %>
              <% else %>
                <div class="card-img-top bg-secondary-subtle d-flex align-items-center justify-content-center text-muted"
                     style="height: 200px;">
                  <i class="fas fa-newspaper fa-3x"></i>
                </div>
              <% end %>
              <div class="card-body">
                <h2 class="h5 fw-semibold text-dark mb-2"><%= post.title %></h2>
                <% if post.excerpt.present? %>
                  <p class="card-text small text-muted mb-2" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">
                    <%= post.excerpt %>
                  </p>
                <% end %>
                <footer class="small text-muted">
                  <i class="fas fa-calendar-day me-1"></i>
                  <%= l post.published_at.to_date, format: :long %>
                </footer>
              </div>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>

    <% if @posts.total_pages > 1 %>
      <nav class="mt-5 d-flex justify-content-center" aria-label="Paginación de blog">
        <%= paginate @posts %>
      </nav>
    <% end %>
  <% else %>
    <div class="text-center py-5">
      <i class="fas fa-newspaper fa-4x text-muted mb-3"></i>
      <h2 class="h5 fw-semibold mb-2">Pronto publicaremos contenido</h2>
      <p class="text-muted">Estamos preparando guías y novedades para coleccionistas. Vuelve pronto.</p>
    </div>
  <% end %>
</div>
